<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Colors -->
    <Color x:Key="SurfaceDark">#FF1B1B1F</Color>
    <Color x:Key="SurfaceMedium">#FF25252B</Color>
    <Color x:Key="SurfaceLight">#FF2A2A30</Color>
    <Color x:Key="AccentPrimary">#FF60A5FA</Color>
    <Color x:Key="AccentSecondary">#FF818CF8</Color>
    <Color x:Key="TextPrimary">#FFE0E0E0</Color>
    <Color x:Key="TextSecondary">#FF999999</Color>
    <Color x:Key="TextMuted">#FF666666</Color>
    <Color x:Key="BorderColor">#FF333338</Color>
    <Color x:Key="DangerColor">#FFF87171</Color>
    <Color x:Key="SuccessColor">#FF34D399</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}" />
    <SolidColorBrush x:Key="SurfaceMediumBrush" Color="{StaticResource SurfaceMedium}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentPrimary}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />

    <!-- Page shadow effect -->
    <DropShadowEffect x:Key="PageShadow" BlurRadius="8" Opacity="0.3"
                       ShadowDepth="2" Color="#FF000000" Direction="270" />

    <!-- Toolbar button -->
    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#FFCCCCCC" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF3A3A42" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#FF4A4A52" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Flat button -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Background" Value="#FF2A2A30" />
        <Setter Property="Foreground" Value="#FFCCCCCC" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#FF3A3A42" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF3A3A42" />
                <Setter Property="BorderBrush" Value="#FF5A5A62" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#FF4A4A52" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Toolbar separator -->
    <Style x:Key="ToolbarSeparator" TargetType="Separator">
        <Setter Property="Background" Value="#FF3A3A42" />
        <Setter Property="Width" Value="1" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Toolbar ComboBox -->
    <Style x:Key="ToolbarComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="#FF2A2A30" />
        <Setter Property="Foreground" Value="#FFCCCCCC" />
        <Setter Property="BorderBrush" Value="#FF3A3A42" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Margin" Value="4,0" />
        <Setter Property="FontSize" Value="12" />
    </Style>
</ResourceDictionary>
