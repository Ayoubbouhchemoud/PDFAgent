<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Stitch "Precision Productivity" — Deep Indigo palette ===== -->

    <!-- Surface -->
    <SolidColorBrush x:Key="SurfaceBrush"                 Color="#F7F9FB" />
    <SolidColorBrush x:Key="SurfaceBrightBrush"           Color="#F7F9FB" />
    <SolidColorBrush x:Key="SurfaceDimBrush"              Color="#D8DADC" />
    <SolidColorBrush x:Key="SurfaceVariantBrush"          Color="#E0E3E5" />
    <SolidColorBrush x:Key="SurfaceContainerLowestBrush"  Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceContainerLowBrush"     Color="#F2F4F6" />
    <SolidColorBrush x:Key="SurfaceContainerBrush"        Color="#ECEEF0" />
    <SolidColorBrush x:Key="SurfaceContainerHighBrush"    Color="#E6E8EA" />
    <SolidColorBrush x:Key="SurfaceContainerHighestBrush" Color="#E0E3E5" />

    <!-- On-Surface -->
    <SolidColorBrush x:Key="OnSurfaceBrush"        Color="#191C1E" />
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#45464E" />
    <SolidColorBrush x:Key="OutlineBrush"          Color="#75777E" />
    <SolidColorBrush x:Key="OutlineVariantBrush"   Color="#C6C6CE" />

    <!-- Primary — Deep Indigo -->
    <SolidColorBrush x:Key="PrimaryBrush"            Color="#182442" />
    <SolidColorBrush x:Key="OnPrimaryBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryContainerBrush"   Color="#2E3A59" />
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#98A4C9" />
    <SolidColorBrush x:Key="PrimaryHoverBrush"       Color="#1E2D52" />
    <SolidColorBrush x:Key="PrimaryPressedBrush"     Color="#121B33" />
    <SolidColorBrush x:Key="PrimaryFixedBrush"       Color="#DAE2FF" />
    <SolidColorBrush x:Key="InversePrimaryBrush"     Color="#BAC6EC" />

    <!-- Secondary -->
    <SolidColorBrush x:Key="SecondaryBrush"            Color="#505F76" />
    <SolidColorBrush x:Key="OnSecondaryBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="SecondaryContainerBrush"   Color="#D0E1FB" />
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#54647A" />

    <!-- Tertiary -->
    <SolidColorBrush x:Key="TertiaryBrush"            Color="#312300" />
    <SolidColorBrush x:Key="OnTertiaryBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="TertiaryContainerBrush"   Color="#4A380C" />
    <SolidColorBrush x:Key="OnTertiaryContainerBrush" Color="#BCA26C" />

    <!-- Error -->
    <SolidColorBrush x:Key="ErrorBrush"            Color="#BA1A1A" />
    <SolidColorBrush x:Key="OnErrorBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="ErrorContainerBrush"   Color="#FFDAD6" />
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#93000A" />

    <!-- Inverse / Scrim -->
    <SolidColorBrush x:Key="ScrimBrush"            Color="#00000080" />
    <SolidColorBrush x:Key="InverseSurfaceBrush"   Color="#2D3133" />
    <SolidColorBrush x:Key="InverseOnSurfaceBrush" Color="#EFF1F3" />

    <!-- Hover / pressed state layers (surface-container tones) -->
    <SolidColorBrush x:Key="StateHoverBrush"   Color="#ECEEF0" />
    <SolidColorBrush x:Key="StateFocusBrush"   Color="#E6E8EA" />
    <SolidColorBrush x:Key="StatePressedBrush" Color="#D8DADC" />

    <!-- Top nav bar -->
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#F7F9FB" />
    <SolidColorBrush x:Key="ToolbarBorderBrush"     Color="#C6C6CE" />

    <!-- Left sidebar -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F2F4F6" />
    <SolidColorBrush x:Key="SidebarBorderBrush"     Color="#C6C6CE" />

    <!-- Nav active state (primary at ~12% on sidebar bg) -->
    <SolidColorBrush x:Key="NavActiveBackgroundBrush" Color="#DCE4F0" />
    <SolidColorBrush x:Key="NavActiveBorderBrush"     Color="#182442" />

    <!-- Thumbnails -->
    <SolidColorBrush x:Key="ThumbnailSelectedBorderBrush"  Color="#182442" />
    <SolidColorBrush x:Key="ThumbnailHoverBackgroundBrush" Color="#DCE4F0" />

    <!-- Document canvas — slightly darker than surface -->
    <SolidColorBrush x:Key="DocumentCanvasBrush" Color="#F1F5F9" />

    <!-- Page shadow: very soft, 5% opacity -->
    <Color x:Key="ShadowColor">#0D000000</Color>

</ResourceDictionary>
