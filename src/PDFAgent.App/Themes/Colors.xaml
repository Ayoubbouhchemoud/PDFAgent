<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Surface ===== -->
    <Color x:Key="SurfaceColor">#FFFFF8F6</Color>
    <Color x:Key="SurfaceVariantColor">#FFF5DED9</Color>
    <Color x:Key="SurfaceContainerLowestColor">#FFFFFFFF</Color>
    <Color x:Key="SurfaceContainerLowColor">#FFFFF0ED</Color>
    <Color x:Key="SurfaceContainerColor">#FFFCE9E5</Color>
    <Color x:Key="SurfaceContainerHighColor">#FFEFE3E0</Color>

    <SolidColorBrush x:Key="SurfaceBrush"                 Color="#FFF8F6" />
    <SolidColorBrush x:Key="SurfaceVariantBrush"          Color="#F5DED9" />
    <SolidColorBrush x:Key="SurfaceContainerLowestBrush"  Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceContainerLowBrush"     Color="#FFF0ED" />
    <SolidColorBrush x:Key="SurfaceContainerBrush"        Color="#FCE9E5" />
    <SolidColorBrush x:Key="SurfaceContainerHighBrush"    Color="#EFE3E0" />

    <!-- ===== On-Surface ===== -->
    <SolidColorBrush x:Key="OnSurfaceBrush"        Color="#201A19" />
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#534341" />
    <SolidColorBrush x:Key="OutlineBrush"          Color="#857371" />
    <SolidColorBrush x:Key="OutlineVariantBrush"   Color="#D8C2BE" />

    <!-- ===== Primary — Terracotta ===== -->
    <SolidColorBrush x:Key="PrimaryBrush"            Color="#9A4023" />
    <SolidColorBrush x:Key="OnPrimaryBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryContainerBrush"   Color="#FFDBD1" />
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="#3A0A00" />
    <SolidColorBrush x:Key="PrimaryHoverBrush"       Color="#7D3318" />
    <SolidColorBrush x:Key="PrimaryPressedBrush"     Color="#612610" />

    <!-- ===== Secondary — Sage ===== -->
    <SolidColorBrush x:Key="SecondaryBrush"            Color="#56642B" />
    <SolidColorBrush x:Key="OnSecondaryBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="SecondaryContainerBrush"   Color="#D8ECA4" />
    <SolidColorBrush x:Key="OnSecondaryContainerBrush" Color="#141F00" />

    <!-- ===== Tertiary — Teal ===== -->
    <SolidColorBrush x:Key="TertiaryBrush"            Color="#006768" />
    <SolidColorBrush x:Key="OnTertiaryBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="TertiaryContainerBrush"   Color="#9DF0F0" />
    <SolidColorBrush x:Key="OnTertiaryContainerBrush" Color="#002020" />

    <!-- ===== Error ===== -->
    <SolidColorBrush x:Key="ErrorBrush"            Color="#BA1A1A" />
    <SolidColorBrush x:Key="OnErrorBrush"          Color="#FFFFFF" />
    <SolidColorBrush x:Key="ErrorContainerBrush"   Color="#FFDAD6" />
    <SolidColorBrush x:Key="OnErrorContainerBrush" Color="#410002" />

    <!-- ===== Inverse / scrim ===== -->
    <SolidColorBrush x:Key="ScrimBrush"            Color="#00000080" />
    <SolidColorBrush x:Key="InverseSurfaceBrush"   Color="#362F2E" />
    <SolidColorBrush x:Key="InverseOnSurfaceBrush" Color="#FFEDE9" />

    <!-- ===== State-layer opacities (as flat brushes used via Opacity) ===== -->
    <SolidColorBrush x:Key="StateHoverBrush"   Color="#9A4023" Opacity="0.08" />
    <SolidColorBrush x:Key="StateFocusBrush"   Color="#9A4023" Opacity="0.12" />
    <SolidColorBrush x:Key="StatePressedBrush" Color="#9A4023" Opacity="0.16" />

    <!-- ===== Toolbar ===== -->
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#FFF0ED" />
    <SolidColorBrush x:Key="ToolbarBorderBrush"     Color="#D8C2BE" />

    <!-- ===== Sidebar ===== -->
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FCE9E5" />
    <SolidColorBrush x:Key="SidebarBorderBrush"     Color="#D8C2BE" />

    <!-- ===== Selected thumbnail ===== -->
    <SolidColorBrush x:Key="ThumbnailSelectedBorderBrush" Color="#9A4023" />
    <SolidColorBrush x:Key="ThumbnailHoverBackgroundBrush" Color="#FFDBD1" />

    <!-- ===== Page shadow ===== -->
    <Color x:Key="ShadowColor">#00000026</Color>

</ResourceDictionary>
