<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Icon Path Geometries ===== -->

    <!-- File Open (folder with arrow) -->
    <Geometry x:Key="IconOpenFile">
        M 2,4 L 2,16 Q 2,18 4,18 L 20,18 Q 22,18 22,16 L 22,8 Q 22,6 20,6 L 11,6 L 9,4 Z
        M 4,4 L 8.5,4 L 10.5,6 L 20,6 L 20,16 L 4,16 Z
    </Geometry>

    <!-- Save (floppy disk) -->
    <Geometry x:Key="IconSaveFile">
        M 5,3 L 5,21 L 19,21 L 19,7 L 15,3 Z
        M 7,3 L 7,9 L 15,9 L 15,3
        M 7,13 L 17,13 L 17,21 L 7,21 Z
    </Geometry>

    <!-- Merge (two arrows converging) -->
    <Geometry x:Key="IconMerge">
        M 8,4 L 12,8 L 8,12 M 16,4 L 12,8 M 12,8 L 12,20
    </Geometry>

    <!-- Split (arrow diverging) -->
    <Geometry x:Key="IconSplit">
        M 12,4 L 12,12 M 12,12 L 8,16 L 8,20 M 12,12 L 16,16 L 16,20
    </Geometry>

    <!-- Rotate (circular arrow) -->
    <Geometry x:Key="IconRotate">
        M 19,8 A 7,7 0 1 0 17,15 M 19,8 L 19,4 L 15,8 Z
    </Geometry>

    <!-- OCR (text scan lines) -->
    <Geometry x:Key="IconOcr">
        M 3,3 L 3,8 M 3,3 L 8,3
        M 21,3 L 16,3 M 21,3 L 21,8
        M 3,21 L 3,16 M 3,21 L 8,21
        M 21,21 L 16,21 M 21,21 L 21,16
        M 7,10 L 17,10 M 7,12 L 17,12 M 7,14 L 14,14
    </Geometry>

    <!-- Redact (black bar) -->
    <Geometry x:Key="IconRedact">
        M 3,8 L 21,8 L 21,12 L 3,12 Z
        M 6,14 L 18,14 M 6,16 L 14,16
    </Geometry>

    <!-- Sign (pen on document) -->
    <Geometry x:Key="IconSign">
        M 4,20 L 8,20 L 8,18 L 4,18 Z
        M 14,4 L 20,10 L 9,21 L 3,21 L 3,15 Z
        M 17,7 L 19,9
    </Geometry>

    <!-- Annotate (speech bubble) -->
    <Geometry x:Key="IconAnnotate">
        M 4,4 Q 4,2 6,2 L 18,2 Q 20,2 20,4 L 20,14 Q 20,16 18,16 L 10,16 L 4,20 L 4,16 L 4,16 Q 2,16 2,14 Z
    </Geometry>

    <!-- Edit Text (pencil on line) -->
    <Geometry x:Key="IconEditText">
        M 3,17 L 7,17 L 18,6 L 14,2 L 3,13 Z
        M 3,21 L 21,21
        M 14,2 L 18,6
    </Geometry>

    <!-- Zoom In (magnifier +) -->
    <Geometry x:Key="IconZoomIn">
        M 11,6 A 5,5 0 1 0 11,16 A 5,5 0 0 0 11,6 Z
        M 9,11 L 13,11 M 11,9 L 11,13
        M 15,15 L 21,21
    </Geometry>

    <!-- Zoom Out (magnifier -) -->
    <Geometry x:Key="IconZoomOut">
        M 11,6 A 5,5 0 1 0 11,16 A 5,5 0 0 0 11,6 Z
        M 9,11 L 13,11
        M 15,15 L 21,21
    </Geometry>

    <!-- Fit Width -->
    <Geometry x:Key="IconFitWidth">
        M 3,12 L 21,12 M 3,12 L 7,8 M 3,12 L 7,16
        M 21,12 L 17,8 M 21,12 L 17,16
    </Geometry>

    <!-- Next Page (chevron right) -->
    <Geometry x:Key="IconNext">M 9,6 L 15,12 L 9,18</Geometry>

    <!-- Previous Page (chevron left) -->
    <Geometry x:Key="IconPrev">M 15,6 L 9,12 L 15,18</Geometry>

    <!-- Search (magnifier) -->
    <Geometry x:Key="IconSearch">
        M 11,5 A 6,6 0 1 0 11,17 A 6,6 0 0 0 11,5 Z
        M 15,15 L 21,21
    </Geometry>

    <!-- Batch Workflow (stacked cards) -->
    <Geometry x:Key="IconBatch">
        M 3,6 L 21,6 L 21,10 L 3,10 Z
        M 3,12 L 21,12 L 21,16 L 3,16 Z
        M 3,18 L 15,18 L 15,22 L 3,22 Z
    </Geometry>

    <!-- Add (plus circle) -->
    <Geometry x:Key="IconAdd">
        M 12,2 A 10,10 0 1 0 12,22 A 10,10 0 0 0 12,2 Z
        M 8,12 L 16,12 M 12,8 L 12,16
    </Geometry>

    <!-- Delete (trash) -->
    <Geometry x:Key="IconDelete">
        M 3,6 L 21,6 M 8,6 L 8,3 L 16,3 L 16,6
        M 5,6 L 5,21 Q 5,22 6,22 L 18,22 Q 19,22 19,21 L 19,6
        M 10,11 L 10,17 M 14,11 L 14,17
    </Geometry>

    <!-- Settings (gear) -->
    <Geometry x:Key="IconSettings">
        M 12,8 A 4,4 0 1 0 12,16 A 4,4 0 0 0 12,8 Z
        M 12,2 L 12,4 M 12,20 L 12,22 M 2,12 L 4,12 M 20,12 L 22,12
        M 5,5 L 6.5,6.5 M 17.5,17.5 L 19,19 M 5,19 L 6.5,17.5 M 17.5,6.5 L 19,5
    </Geometry>

    <!-- Close (X) -->
    <Geometry x:Key="IconClose">M 5,5 L 19,19 M 19,5 L 5,19</Geometry>

    <!-- Accept / Checkmark -->
    <Geometry x:Key="IconAccept">M 5,12 L 10,17 L 19,7</Geometry>

    <!-- Reject / Cross -->
    <Geometry x:Key="IconReject">M 6,6 L 18,18 M 18,6 L 6,18</Geometry>

    <!-- Export (arrow up from box) -->
    <Geometry x:Key="IconExport">
        M 12,3 L 12,15 M 8,7 L 12,3 L 16,7
        M 5,17 L 5,21 L 19,21 L 19,17
    </Geometry>

    <!-- Print (printer) -->
    <Geometry x:Key="IconPrint">
        M 6,9 L 6,3 L 18,3 L 18,9
        M 4,9 Q 2,9 2,11 L 2,17 Q 2,19 4,19 L 6,19 L 6,15 L 18,15 L 18,19 L 20,19 Q 22,19 22,17 L 22,11 Q 22,9 20,9 Z
        M 6,15 L 6,21 L 18,21 L 18,15 Z
    </Geometry>

    <!-- Play / Run workflow -->
    <Geometry x:Key="IconPlay">M 6,4 L 20,12 L 6,20 Z</Geometry>

    <!-- Drag handle (dots) -->
    <Geometry x:Key="IconDragHandle">
        M 8,5 A 1,1 0 1 0 8,7 A 1,1 0 0 0 8,5 Z
        M 16,5 A 1,1 0 1 0 16,7 A 1,1 0 0 0 16,5 Z
        M 8,11 A 1,1 0 1 0 8,13 A 1,1 0 0 0 8,11 Z
        M 16,11 A 1,1 0 1 0 16,13 A 1,1 0 0 0 16,11 Z
        M 8,17 A 1,1 0 1 0 8,19 A 1,1 0 0 0 8,17 Z
        M 16,17 A 1,1 0 1 0 16,19 A 1,1 0 0 0 16,17 Z
    </Geometry>

    <!-- ===== Shared Path Style (20×20 icon, PrimaryBrush stroke, no fill) ===== -->
    <Style x:Key="IconPath" TargetType="Path">
        <Setter Property="Stroke"          Value="{DynamicResource OnSurfaceBrush}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="Fill"            Value="Transparent" />
        <Setter Property="StrokeLineJoin"  Value="Round" />
        <Setter Property="StrokeStartLineCap" Value="Round" />
        <Setter Property="StrokeEndLineCap"   Value="Round" />
        <Setter Property="Stretch"         Value="Uniform" />
        <Setter Property="Width"           Value="16" />
        <Setter Property="Height"          Value="16" />
    </Style>

    <Style x:Key="IconPathPrimary" BasedOn="{StaticResource IconPath}" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <Style x:Key="IconPathOnPrimary" BasedOn="{StaticResource IconPath}" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource OnPrimaryBrush}" />
    </Style>

</ResourceDictionary>
