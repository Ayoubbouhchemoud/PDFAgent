    <!-- Document icon -->
    <Geometry x:Key="IconDocument">M 4,2 L 16,2 L 20,6 L 20,22 L 4,22 Z M 16,2 L 16,6 L 20,6 M 8,10 L 16,10 M 8,14 L 16,14 M 8,18 L 12,18</Geometry>

    <!-- Folder open -->
    <Geometry x:Key="IconFolderOpen">M 2,6 Q 2,4 4,4 L 9,4 L 11,6 L 20,6 Q 22,6 22,8 L 22,18 Q 22,20 20,20 L 4,20 Q 2,20 2,18 Z M 2,10 L 22,10</Geometry>

    <!-- ===== Shared icon path style — variant color, no fill, round caps ===== -->
    <Style x:Key="IconPath" TargetType="Path">
        <Setter Property="Stroke"               Value="{DynamicResource OnSurfaceVariantBrush}" />
        <Setter Property="StrokeThickness"      Value="1.5" />
        <Setter Property="Fill"                 Value="Transparent" />
        <Setter Property="StrokeLineJoin"       Value="Round" />
        <Setter Property="StrokeStartLineCap"   Value="Round" />
        <Setter Property="StrokeEndLineCap"     Value="Round" />
        <Setter Property="Stretch"              Value="Uniform" />
        <Setter Property="Width"                Value="16" />
        <Setter Property="Height"               Value="16" />
    </Style>

    <!-- Primary-colored icon -->
    <Style x:Key="IconPathPrimary" BasedOn="{StaticResource IconPath}" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource PrimaryBrush}" />
    </Style>

    <!-- White icon (on primary button) -->
    <Style x:Key="IconPathOnPrimary" BasedOn="{StaticResource IconPath}" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource OnPrimaryBrush}" />
    </Style>

    <!-- Error-colored icon -->
    <Style x:Key="IconPathError" BasedOn="{StaticResource IconPath}" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource ErrorBrush}" />
    </Style>

    <!-- Nav icon — 20px, variant color -->
    <Style x:Key="NavIconPath" TargetType="Path">
        <Setter Property="Stroke"               Value="{DynamicResource OnSurfaceVariantBrush}" />
        <Setter Property="StrokeThickness"      Value="1.5" />
        <Setter Property="Fill"                 Value="Transparent" />
        <Setter Property="StrokeLineJoin"       Value="Round" />
        <Setter Property="StrokeStartLineCap"   Value="Round" />
        <Setter Property="StrokeEndLineCap"     Value="Round" />
        <Setter Property="Stretch"              Value="Uniform" />
        <Setter Property="Width"                Value="18" />
        <Setter Property="Height"               Value="18" />
    </Style>

    <!-- Active nav icon — primary color -->
    <Style x:Key="NavIconPathActive" BasedOn="{StaticResource NavIconPath}" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource PrimaryBrush}" />
    </Style>

</ResourceDictionary>
