<Window x:Class="PDFAgent.App.Views.SplitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split PDF"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <StackPanel Margin="24,20">

        <!-- Header -->
        <TextBlock Text="Split PDF"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,20" />

        <!-- SPLIT MODE label -->
        <TextBlock Text="SPLIT MODE"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10" />

        <!-- Option 1: Split all -->
        <RadioButton x:Name="RadioSplitAll"
                     GroupName="Mode"
                     IsChecked="True"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,2"
                     Checked="Mode_Checked">
            <TextBlock Text="Split all pages" />
        </RadioButton>
        <TextBlock Text="Each page is saved as a separate PDF file."
                   FontSize="11" Foreground="{DynamicResource OutlineBrush}"
                   Margin="20,0,0,12" />

        <!-- Option 2: Extract range -->
        <RadioButton x:Name="RadioExtract"
                     GroupName="Mode"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,2"
                     Checked="Mode_Checked">
            <TextBlock Text="Extract pages to one PDF" />
        </RadioButton>
        <TextBlock Text="Save the specified pages as a single new PDF."
                   FontSize="11" Foreground="{DynamicResource OutlineBrush}"
                   Margin="20,0,0,6" />
        <StackPanel Orientation="Horizontal" Margin="20,0,0,4">
            <TextBlock Text="Pages:" FontSize="13"
                       Foreground="{DynamicResource OnSurfaceBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="PageRangeBox"
                     Style="{StaticResource InputTextBox}"
                     Width="180" IsEnabled="False"
                     ToolTip="e.g. 1, 3-5, 7-10" />
        </StackPanel>
        <TextBlock x:Name="RangeHint"
                   Text="e.g. 1, 3-5, 7-10"
                   FontSize="11" Foreground="{DynamicResource OutlineBrush}"
                   Margin="20,0,0,12" />

        <!-- Option 3: Every N pages -->
        <RadioButton x:Name="RadioEveryN"
                     GroupName="Mode"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,2"
                     Checked="Mode_Checked">
            <TextBlock Text="Split every N pages" />
        </RadioButton>
        <TextBlock Text="Creates multiple PDFs, each containing N consecutive pages."
                   FontSize="11" Foreground="{DynamicResource OutlineBrush}"
                   Margin="20,0,0,6" />
        <StackPanel Orientation="Horizontal" Margin="20,0,0,4">
            <TextBlock Text="Every" FontSize="13"
                       Foreground="{DynamicResource OnSurfaceBrush}"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="EveryNBox"
                     Text="2"
                     Style="{StaticResource InputTextBox}"
                     Width="60" IsEnabled="False" />
            <TextBlock Text="pages" FontSize="13"
                       Foreground="{DynamicResource OnSurfaceBrush}"
                       VerticalAlignment="Center" Margin="8,0,0,0" />
        </StackPanel>

        <!-- Validation message -->
        <TextBlock x:Name="ValidationMsg"
                   FontSize="12"
                   Foreground="#CC2200"
                   Margin="0,12,0,0"
                   Visibility="Collapsed" />

        <Separator Background="{DynamicResource OutlineVariantBrush}" Margin="0,16,0,16" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource OutlinedButton}"
                    Width="96" Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
            <Button Content="Split →"
                    Style="{StaticResource FilledButton}"
                    Width="96"
                    IsDefault="True"
                    Click="Split_Click" />
        </StackPanel>

    </StackPanel>
</Window>
