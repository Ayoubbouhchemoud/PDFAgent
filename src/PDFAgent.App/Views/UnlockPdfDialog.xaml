<Window x:Class="PDFAgent.App.Views.UnlockPdfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remove PDF Protection"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <StackPanel Margin="24,20">

        <TextBlock Text="Remove PDF Protection"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,4"/>

        <TextBlock TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,20">
            Enter the user or owner password to remove protection.
            The original file is never modified — a new unencrypted copy is saved.
        </TextBlock>

        <TextBlock Text="Password"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,6"/>

        <PasswordBox x:Name="PwBox"
                     FontSize="13"
                     Background="{DynamicResource SurfaceVariantBrush}"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     Margin="0,0,0,4"
                     KeyDown="PwBox_KeyDown"/>

        <TextBlock x:Name="ErrorLabel"
                   Foreground="#EF5350"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"
                   Visibility="Collapsed"/>

        <Separator Background="{DynamicResource OutlineVariantBrush}" Margin="0,16,0,12"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource OutlinedButton}"
                    Width="90" Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="Remove Protection"
                    Style="{StaticResource FilledButton}"
                    Width="150"
                    IsDefault="True"
                    Click="Remove_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
