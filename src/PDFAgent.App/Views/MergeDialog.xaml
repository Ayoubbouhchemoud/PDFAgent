<Window x:Class="PDFAgent.App.Views.MergeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Merge PDFs"
        Width="520" Height="500"
        MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Merge PDFs"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,16" />

        <!-- Files label + Add button -->
        <Grid Grid.Row="1" Margin="0,0,0,6">
            <TextBlock Text="FILES TO MERGE  (drag selection, use ↑↓ to reorder)"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       VerticalAlignment="Center" />
            <Button x:Name="AddFilesBtn"
                    Content="+ Add Files"
                    Style="{StaticResource OutlinedButton}"
                    HorizontalAlignment="Right"
                    Height="28" Padding="10,0"
                    FontSize="12"
                    Click="AddFiles_Click" />
        </Grid>

        <!-- File list -->
        <ListBox x:Name="FileList"
                 Grid.Row="2"
                 SelectionMode="Single"
                 Background="{DynamicResource SurfaceContainerLowBrush}"
                 BorderBrush="{DynamicResource OutlineVariantBrush}"
                 BorderThickness="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="FileList_SelectionChanged">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="8,5" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Index badge -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource PrimaryContainerBrush}"
                                CornerRadius="3"
                                Padding="5,1"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Index}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource OnPrimaryContainerBrush}" />
                        </Border>
                        <!-- File info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FileName}"
                                       FontSize="13"
                                       Foreground="{DynamicResource OnSurfaceBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SubText}"
                                       FontSize="11"
                                       Foreground="{DynamicResource OutlineBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Reorder / remove buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,6,0,0">
            <Button x:Name="MoveUpBtn"
                    Content="↑ Move Up"
                    Style="{StaticResource OutlinedButton}"
                    Height="28" Padding="10,0"
                    FontSize="12" IsEnabled="False"
                    Margin="0,0,6,0"
                    Click="MoveUp_Click" />
            <Button x:Name="MoveDownBtn"
                    Content="↓ Move Down"
                    Style="{StaticResource OutlinedButton}"
                    Height="28" Padding="10,0"
                    FontSize="12" IsEnabled="False"
                    Margin="0,0,6,0"
                    Click="MoveDown_Click" />
            <Button x:Name="RemoveBtn"
                    Content="✕ Remove"
                    Style="{StaticResource OutlinedButton}"
                    Height="28" Padding="10,0"
                    FontSize="12" IsEnabled="False"
                    Click="Remove_Click" />
        </StackPanel>

        <!-- Summary -->
        <TextBlock x:Name="SummaryText"
                   Grid.Row="4"
                   FontSize="12"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,10,0,0" />

        <!-- Validation error -->
        <TextBlock x:Name="ValidationMsg"
                   Grid.Row="5"
                   FontSize="12"
                   Foreground="#CC2200"
                   Margin="0,6,0,0"
                   Visibility="Collapsed" />

        <!-- Separator + buttons -->
        <Grid Grid.Row="6" Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Separator Grid.Row="0"
                       Background="{DynamicResource OutlineVariantBrush}"
                       Margin="0,0,0,14" />
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource OutlinedButton}"
                        Width="96" Margin="0,0,8,0"
                        IsCancel="True"
                        Click="Cancel_Click" />
                <Button Content="Merge →"
                        Style="{StaticResource FilledButton}"
                        Width="96"
                        IsDefault="True"
                        Click="Merge_Click" />
            </StackPanel>
        </Grid>

    </Grid>
</Window>
