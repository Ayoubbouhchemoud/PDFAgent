<Window x:Class="PDFAgent.App.Views.SignaturePlacementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Place Signature"
        Width="360" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <StackPanel Margin="24,20">

        <TextBlock Text="Place Signature"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,20" />

        <!-- Page selection -->
        <TextBlock Text="PAGE"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,8" />

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBox x:Name="PageNumberBox"
                     Width="64"
                     Style="{StaticResource InputTextBox}"
                     Text="1"
                     HorizontalContentAlignment="Center" />
            <TextBlock x:Name="TotalPagesLabel"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       FontSize="13"
                       Margin="10,0,0,0"
                       Text="of 1" />
        </StackPanel>

        <!-- Position selection -->
        <TextBlock Text="POSITION"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10" />

        <RadioButton x:Name="RadioBottomRight"
                     Content="Bottom right  (default)"
                     GroupName="Placement"
                     IsChecked="True"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,6" />
        <RadioButton x:Name="RadioBottomCenter"
                     Content="Bottom center"
                     GroupName="Placement"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,6" />
        <RadioButton x:Name="RadioBottomLeft"
                     Content="Bottom left"
                     GroupName="Placement"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,24" />

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource OutlinedButton}"
                    Width="96"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
            <Button Content="Place"
                    Style="{StaticResource FilledButton}"
                    Width="96"
                    IsDefault="True"
                    Click="Place_Click" />
        </StackPanel>

    </StackPanel>
</Window>
