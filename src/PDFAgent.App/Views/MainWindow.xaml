<Window x:Class="PDFAgent.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PDFAgent.App.ViewModels"
        xmlns:converters="clr-namespace:PDFAgent.App.Converters"
        Title="PDF Agent" Height="900" Width="1400"
        WindowState="Maximized"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.Resources>
        <converters:BytesToImageConverter x:Key="BytesToImage" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- ===== TOOLBAR ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource ToolbarBorderBrush}"
                BorderThickness="0,0,0,1"
                Effect="{StaticResource ToolbarShadow}">
            <DockPanel Margin="8,0" VerticalAlignment="Center">

                <!-- App wordmark -->
                <TextBlock DockPanel.Dock="Left"
                           Text="PDF Agent"
                           FontFamily="{DynamicResource HeadingFont}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,16,0" />

                <!-- File group -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenFileCommand}" ToolTip="Open PDF">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconOpenFile}" Margin="0,0,4,0" />
                            <TextBlock Text="Open" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding SaveFileCommand}" ToolTip="Save">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSaveFile}" Margin="0,0,4,0" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>
                    <Separator Style="{StaticResource ToolbarSeparator}" />
                </StackPanel>

                <!-- Edit group -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding MergeCommand}"    ToolTip="Merge PDFs">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconMerge}" Margin="0,0,4,0" />
                            <TextBlock Text="Merge" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding SplitCommand}"    ToolTip="Split PDF">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSplit}" Margin="0,0,4,0" />
                            <TextBlock Text="Split" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding RotateCommand}"   ToolTip="Rotate page">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconRotate}" Margin="0,0,4,0" />
                            <TextBlock Text="Rotate" />
                        </StackPanel>
                    </Button>
                    <Separator Style="{StaticResource ToolbarSeparator}" />
                </StackPanel>

                <!-- Tools group -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding OcrCommand}"      ToolTip="Run OCR">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconOcr}" Margin="0,0,4,0" />
                            <TextBlock Text="OCR" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding RedactCommand}"   ToolTip="Redact content">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconRedact}" Margin="0,0,4,0" />
                            <TextBlock Text="Redact" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding SignCommand}"      ToolTip="Sign document">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSign}" Margin="0,0,4,0" />
                            <TextBlock Text="Sign" />
                        </StackPanel>
                    </Button>
                    <Separator Style="{StaticResource ToolbarSeparator}" />
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding AnnotateCommand}" ToolTip="Annotate">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconAnnotate}" Margin="0,0,4,0" />
                            <TextBlock Text="Annotate" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarButton}" IsEnabled="False"
                            ToolTip="Text editing is not available in this version">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconEditText}" Margin="0,0,4,0" />
                            <TextBlock Text="Edit Text" />
                        </StackPanel>
                    </Button>
                    <Separator Style="{StaticResource ToolbarSeparator}" />
                    <!-- Batch Workflow shortcut -->
                    <Button Style="{StaticResource ToolbarButton}" Command="{Binding OpenBatchWorkflowCommand}" ToolTip="Batch workflows">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconBatch}" Margin="0,0,4,0" />
                            <TextBlock Text="Batch" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right cluster: zoom + page -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Style="{StaticResource IconButton}" Command="{Binding ZoomOutCommand}" ToolTip="Zoom out">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconZoomOut}" />
                    </Button>
                    <ComboBox ItemsSource="{Binding ZoomLevels}"
                              SelectedItem="{Binding CurrentZoom}"
                              Style="{StaticResource ToolbarComboBox}"
                              Width="76" Margin="2,0" />
                    <Button Style="{StaticResource IconButton}" Command="{Binding ZoomInCommand}" ToolTip="Zoom in">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconZoomIn}" />
                    </Button>
                    <Separator Style="{StaticResource ToolbarSeparator}" />
                    <Button Style="{StaticResource IconButton}" Command="{Binding PreviousPageCommand}" ToolTip="Previous page">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconPrev}" />
                    </Button>
                    <TextBlock Text="{Binding CurrentPage, StringFormat='{}{0}'}"
                               VerticalAlignment="Center" Margin="4,0"
                               FontSize="13" Foreground="{DynamicResource OnSurfaceVariantBrush}" />
                    <TextBlock Text="/" VerticalAlignment="Center" FontSize="13"
                               Foreground="{DynamicResource OutlineBrush}" />
                    <TextBlock Text="{Binding TotalPages}"
                               VerticalAlignment="Center" Margin="4,0"
                               FontSize="13" Foreground="{DynamicResource OnSurfaceVariantBrush}" />
                    <Button Style="{StaticResource IconButton}" Command="{Binding NextPageCommand}" ToolTip="Next page">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconNext}" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ThumbnailColumn" Width="216" MinWidth="120" MaxWidth="360" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition x:Name="PropertiesColumn" Width="300" MinWidth="200" MaxWidth="480" />
            </Grid.ColumnDefinitions>

            <!-- ── Thumbnail strip ── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Panel header -->
                    <Border Grid.Row="0" Padding="12,10,8,8">
                        <DockPanel>
                            <TextBlock Text="PAGES" Style="{StaticResource SectionHeader}"
                                       DockPanel.Dock="Left" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TotalPages, StringFormat='{}{0}'}"
                                       DockPanel.Dock="Right"
                                       FontFamily="{DynamicResource BodyFont}"
                                       FontSize="12"
                                       Foreground="{DynamicResource OutlineBrush}"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             Style="{StaticResource ChromelessListBox}"
                             ItemContainerStyle="{StaticResource ThumbnailListBoxItem}"
                             ItemsSource="{Binding Thumbnails}"
                             SelectedItem="{Binding SelectedPage}"
                             Padding="4,0,4,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Background="{DynamicResource SurfaceContainerLowestBrush}"
                                            CornerRadius="4"
                                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                                            BorderThickness="1">
                                        <Image Source="{Binding Thumbnail, Converter={StaticResource BytesToImage}}"
                                               MaxWidth="160" MaxHeight="220"
                                               Stretch="Uniform"
                                               Margin="4" />
                                    </Border>
                                    <TextBlock Text="{Binding PageNumber, StringFormat='Page {0}'}"
                                               Style="{StaticResource LabelSmall}"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Splitter left -->
            <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                          HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <!-- ── PDF Viewer ── -->
            <Border Grid.Column="2" Background="{DynamicResource SurfaceContainerBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Search bar strip -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceContainerLowBrush}"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,6"
                            Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                    Command="{Binding CloseSearchCommand}" ToolTip="Close">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource IconClose}" />
                            </Button>
                            <Path DockPanel.Dock="Left" Style="{StaticResource IconPath}"
                                  Data="{StaticResource IconSearch}"
                                  VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBox}"
                                     VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <!-- Page canvas -->
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="{DynamicResource SurfaceContainerBrush}"
                                  Padding="0,8">
                        <ItemsControl ItemsSource="{Binding RenderedPages}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SurfaceContainerLowestBrush}"
                                            CornerRadius="3"
                                            Effect="{StaticResource PageShadow}"
                                            HorizontalAlignment="Center"
                                            Margin="24,8">
                                        <Image Source="{Binding ImageData, Converter={StaticResource BytesToImage}}"
                                               Stretch="None">
                                            <Image.LayoutTransform>
                                                <ScaleTransform
                                                    ScaleX="{Binding DataContext.CurrentZoom,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    ScaleY="{Binding DataContext.CurrentZoom,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                            </Image.LayoutTransform>
                                        </Image>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding IsDocumentEmpty, Converter={StaticResource BoolToVis}}">
                        <Path Style="{StaticResource IconPath}"
                              Data="{StaticResource IconOpenFile}"
                              Width="48" Height="48"
                              Stroke="{DynamicResource OutlineBrush}"
                              HorizontalAlignment="Center" />
                        <TextBlock Text="Open a PDF to get started"
                                   Style="{StaticResource TitleMedium}"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,8" />
                        <Button Content="Open PDF"
                                Style="{StaticResource FilledButton}"
                                Command="{Binding OpenFileCommand}"
                                HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Splitter right -->
            <GridSplitter Grid.Column="3" Width="4" Background="Transparent"
                          HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <!-- ── Properties / Info panel ── -->
            <Border Grid.Column="4"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,12">

                        <!-- Document info -->
                        <TextBlock Text="DOCUMENT" Style="{StaticResource SectionHeader}" />

                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="File"
                                               Style="{StaticResource PropertyLabel}"
                                               Width="72" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DocumentInfo.FileName}"
                                               Style="{StaticResource BodySmall}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding DocumentInfo.FilePath}" />
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Pages"    Style="{StaticResource PropertyLabel}" Width="72" />
                                    <TextBlock Grid.Column="1" Text="{Binding DocumentInfo.PageCount}" Style="{StaticResource BodySmall}" />
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Size"     Style="{StaticResource PropertyLabel}" Width="72" />
                                    <TextBlock Grid.Column="1" Text="{Binding DocumentInfo.FileSizeKB, StringFormat='{}{0} KB'}" Style="{StaticResource BodySmall}" />
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Author"   Style="{StaticResource PropertyLabel}" Width="72" />
                                    <TextBlock Grid.Column="1" Text="{Binding DocumentInfo.Author}" Style="{StaticResource BodySmall}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Title"    Style="{StaticResource PropertyLabel}" Width="72" />
                                    <TextBlock Grid.Column="1" Text="{Binding DocumentInfo.Title}" Style="{StaticResource BodySmall}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="PDF Ver." Style="{StaticResource PropertyLabel}" Width="72" />
                                    <TextBlock Grid.Column="1" Text="{Binding DocumentInfo.PdfVersion}" Style="{StaticResource BodySmall}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Separator Style="{StaticResource PanelSeparator}" />

                        <!-- Quick actions -->
                        <TextBlock Text="ACTIONS" Style="{StaticResource SectionHeader}" />
                        <Button Content="Export to Image" Style="{StaticResource FlatButton}" Margin="0,0,0,6"
                                Command="{Binding ExportToImageCommand}" />
                        <Button Content="Print"           Style="{StaticResource FlatButton}" Margin="0,0,0,6"
                                Command="{Binding PrintCommand}" />
                        <Button Content="Properties…"     Style="{StaticResource FlatButton}" Margin="0,0,0,6"
                                Command="{Binding PropertiesCommand}" />

                        <Separator Style="{StaticResource PanelSeparator}" />

                        <!-- Workflow -->
                        <TextBlock Text="WORKFLOWS" Style="{StaticResource SectionHeader}" />
                        <Button Style="{StaticResource TonalButton}"
                                Command="{Binding OpenBatchWorkflowCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource IconBatch}"
                                      Stroke="{DynamicResource OnPrimaryContainerBrush}"
                                      Margin="0,0,6,0" />
                                <TextBlock Text="New Batch Workflow" />
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource PanelSeparator}" />

                        <!-- OCR Review shortcut -->
                        <TextBlock Text="OCR" Style="{StaticResource SectionHeader}" />
                        <Button Content="Review OCR Results"
                                Style="{StaticResource OutlinedButton}"
                                Command="{Binding OpenOcrReviewCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center" />

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="2"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource ToolbarBorderBrush}"
                BorderThickness="0,1,0,0">
            <StatusBar Style="{StaticResource AppStatusBar}" Padding="8,0">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusText}" />
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Pages: " />
                        <TextBlock Text="{Binding TotalPages}" FontWeight="SemiBold" />
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>
        </Border>

    </Grid>
</Window>
