<Window x:Class="PDFAgent.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PDFAgent.App.ViewModels"
        xmlns:converters="clr-namespace:PDFAgent.App.Converters"
        xmlns:local="clr-namespace:PDFAgent.App.Views"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PDF Professional" Height="900" Width="1400"
        WindowState="Maximized"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.Resources>
        <converters:BytesToImageConverter x:Key="BytesToImage" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}" />
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ToggleTextEditModeCommand}" />
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding OpenSearchCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <!-- ===== TOP NAV BAR ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1"
                Effect="{StaticResource ToolbarShadow}">
            <DockPanel Margin="16,0" VerticalAlignment="Center">

                <!-- Brand -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="{StaticResource IconDocument}"
                          Style="{StaticResource IconPath}"
                          Stroke="{DynamicResource PrimaryBrush}"
                          Width="20" Height="20"
                          Margin="0,0,8,0" />
                    <TextBlock Text="PDF Professional"
                               FontFamily="{DynamicResource HeadingFont}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0" />
                </StackPanel>

                <!-- Right cluster: icon-only toolbar buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Page navigation -->
                    <Button Style="{StaticResource IconButton}" Command="{Binding PreviousPageCommand}" ToolTip="Previous page">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconPrev}" />
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2,0">
                        <TextBlock Text="{Binding CurrentPage, StringFormat='{}{0}'}"
                                   FontSize="13" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" / " FontSize="13" Foreground="{DynamicResource OutlineBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding TotalPages}"
                                   FontSize="13" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Style="{StaticResource IconButton}" Command="{Binding NextPageCommand}" ToolTip="Next page">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconNext}" />
                    </Button>

                    <Separator Style="{StaticResource ToolbarSeparator}" />

                    <!-- Zoom -->
                    <Button Style="{StaticResource IconButton}" Command="{Binding ZoomOutCommand}" ToolTip="Zoom out">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconZoomOut}" />
                    </Button>
                    <ComboBox ItemsSource="{Binding ZoomLevels}"
                              SelectedItem="{Binding CurrentZoom}"
                              Style="{StaticResource ToolbarComboBox}"
                              Width="72" Margin="2,0" />
                    <Button Style="{StaticResource IconButton}" Command="{Binding ZoomInCommand}" ToolTip="Zoom in">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconZoomIn}" />
                    </Button>

                    <Separator Style="{StaticResource ToolbarSeparator}" />

                    <!-- Tools -->
                    <Button Style="{StaticResource IconButton}" Command="{Binding OcrCommand}" ToolTip="Run OCR">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconOcr}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding RedactCommand}" ToolTip="Redact content">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconRedact}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding SignCommand}" ToolTip="Sign document (drag sticker to position)">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSign}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ApplyTextAnnotationsCommand}"
                            ToolTip="Apply text annotations to PDF  (double-click any page to add text)">
                        <TextBlock Text="T↓" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ToggleTextEditModeCommand}"
                            ToolTip="Edit existing PDF text — click words to replace them">
                        <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✎" />
                                    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTextEditMode}" Value="True">
                                            <Setter Property="Foreground" Value="#0078D4" />
                                            <Setter Property="Text" Value="✎●" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ApplyTextEditsCommand}"
                            ToolTip="Commit text edits to PDF">
                        <TextBlock FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✎✓" />
                                    <Setter Property="Foreground" Value="{DynamicResource OnSurfaceVariantBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTextEditMode}" Value="True">
                                            <Setter Property="Foreground" Value="#107C10" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding AnnotateCommand}" ToolTip="Annotate">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconAnnotate}" />
                    </Button>

                    <Separator Style="{StaticResource ToolbarSeparator}" />

                    <!-- Edit -->
                    <Button Style="{StaticResource IconButton}" Command="{Binding MergeCommand}" ToolTip="Merge PDFs">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconMerge}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding SplitCommand}" ToolTip="Split PDF">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSplit}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding AddPageCommand}" ToolTip="Add blank page">
                        <TextBlock Text="＋" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding RotateCommand}" ToolTip="Rotate page">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconRotate}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ReduceSizeCommand}" ToolTip="Reduce PDF size">
                        <TextBlock Text="⇩" FontSize="15"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ConvertToPdfCommand}" ToolTip="Convert file to PDF (images, Word, Excel, PowerPoint, TXT)">
                        <TextBlock Text="⇌" FontSize="15"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding ConvertFromPdfCommand}" ToolTip="Convert PDF to images, Word, or text">
                        <TextBlock Text="⇒" FontSize="15"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding UndoCommand}" ToolTip="Undo last operation (Ctrl+Z)">
                        <TextBlock Text="↩" FontSize="15"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </Button>

                    <Separator Style="{StaticResource ToolbarSeparator}" />

                    <!-- File -->
                    <Button Style="{StaticResource IconButton}" Command="{Binding OpenFileCommand}" ToolTip="Open PDF">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconOpenFile}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding SaveFileCommand}" ToolTip="Save PDF">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSaveFile}" />
                    </Button>
                    <Button Style="{StaticResource IconButton}" Command="{Binding CloseFileCommand}" ToolTip="Close document">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconClose}" />
                    </Button>

                </StackPanel>

                <!-- Center: inline search bar -->
                <Border Background="{DynamicResource SurfaceContainerLowBrush}"
                        BorderBrush="{DynamicResource OutlineVariantBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,0"
                        MaxWidth="400"
                        Height="36"
                        VerticalAlignment="Center"
                        MouseDown="SearchBorder_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Search icon / submit button -->
                        <Button Grid.Column="0"
                                Style="{StaticResource IconButton}"
                                Command="{Binding SearchCommand}"
                                ToolTip="Search (Enter)">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSearch}" />
                        </Button>

                        <!-- TextBox + placeholder overlay -->
                        <Grid Grid.Column="1">
                            <TextBox x:Name="SearchQueryTextBox"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBox}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     FontSize="13"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter"  Command="{Binding SearchCommand}" />
                                    <KeyBinding Key="Escape" Command="{Binding CloseSearchCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <!-- Placeholder — hidden as soon as the user types anything -->
                            <TextBlock IsHitTestVisible="False"
                                       Text="Search in document…"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="{DynamicResource OutlineBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Clear / close button — shown while a search is active -->
                        <Button Grid.Column="2"
                                Style="{StaticResource IconButton}"
                                Command="{Binding CloseSearchCommand}"
                                ToolTip="Close search (Esc)"
                                Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVis}}">
                            <Path Style="{StaticResource IconPath}" Data="{StaticResource IconClose}" />
                        </Button>
                    </Grid>
                </Border>

            </DockPanel>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180" MaxWidth="380" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition x:Name="PropertiesColumn" Width="300" MinWidth="200" MaxWidth="480" />
            </Grid.ColumnDefinitions>

            <!-- ── Left Sidebar: Nav + Thumbnails ── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Section header -->
                    <Border Grid.Row="0" Padding="16,14,12,6">
                        <TextBlock Text="DOCUMENT STRUCTURE"
                                   Style="{StaticResource SectionHeader}"
                                   Margin="0" />
                    </Border>

                    <!-- Nav items -->
                    <StackPanel Grid.Row="1" Margin="8,0,8,8">
                        <!-- Pages is always the active view -->
                        <Button Style="{StaticResource NavItemButtonActive}" Margin="0,1">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource NavIconPathActive}"
                                      Data="{StaticResource IconGridView}"
                                      Margin="0,0,10,0" />
                                <TextBlock Text="Pages" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavItemButton}" Margin="0,1"
                                IsEnabled="False" ToolTip="Not available in this version">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource NavIconPath}"
                                      Data="{StaticResource IconOutline}"
                                      Margin="0,0,10,0" />
                                <TextBlock Text="Outlines" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavItemButton}" Margin="0,1"
                                IsEnabled="False" ToolTip="Not available in this version">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource NavIconPath}"
                                      Data="{StaticResource IconBookmark}"
                                      Margin="0,0,10,0" />
                                <TextBlock Text="Bookmarks" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavItemButton}" Margin="0,1"
                                IsEnabled="False" ToolTip="Not available in this version">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource NavIconPath}"
                                      Data="{StaticResource IconLayers}"
                                      Margin="0,0,10,0" />
                                <TextBlock Text="Layers" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Thumbnail strip -->
                    <ListBox Grid.Row="2"
                             Style="{StaticResource ChromelessListBox}"
                             ItemContainerStyle="{StaticResource ThumbnailListBoxItem}"
                             ItemsSource="{Binding Thumbnails}"
                             SelectedItem="{Binding SelectedPage}"
                             Padding="4,0,4,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Background="{DynamicResource SurfaceContainerLowestBrush}"
                                            CornerRadius="4"
                                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                                            BorderThickness="1">
                                        <Image Source="{Binding Thumbnail, Converter={StaticResource BytesToImage}}"
                                               MaxWidth="160" MaxHeight="220"
                                               Stretch="Uniform"
                                               Margin="4" />
                                    </Border>
                                    <TextBlock Text="{Binding PageNumber, StringFormat='Page {0}'}"
                                               Style="{StaticResource LabelSmall}"
                                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Footer nav -->
                    <Border Grid.Row="3"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="8,8">
                        <StackPanel>
                            <Button Style="{StaticResource NavItemButton}" Margin="0,1">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource NavIconPath}"
                                          Data="{StaticResource IconSettings}"
                                          Margin="0,0,10,0" />
                                    <TextBlock Text="Settings" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavItemButton}" Margin="0,1">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource NavIconPath}"
                                          Data="{StaticResource IconHelp}"
                                          Margin="0,0,10,0" />
                                    <TextBlock Text="Help" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- Splitter left -->
            <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                          HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <!-- ── PDF Viewer ── -->
            <Border Grid.Column="2" Background="{DynamicResource DocumentCanvasBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Search results strip — visible while a search is active -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceContainerLowBrush}"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="12,5"
                            Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <!-- Close -->
                            <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                    Command="{Binding CloseSearchCommand}" ToolTip="Close search (Esc)">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource IconClose}" />
                            </Button>
                            <!-- Next match -->
                            <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                    Command="{Binding SearchNextCommand}" ToolTip="Next match">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource IconNext}" />
                            </Button>
                            <!-- Previous match -->
                            <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}"
                                    Command="{Binding SearchPrevCommand}" ToolTip="Previous match">
                                <Path Style="{StaticResource IconPath}" Data="{StaticResource IconPrev}" />
                            </Button>
                            <!-- "3 / 15" position counter -->
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding SearchCurrentPosition}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                       Margin="6,0" />
                            <!-- Search icon -->
                            <Path DockPanel.Dock="Left" Style="{StaticResource IconPath}"
                                  Data="{StaticResource IconSearch}"
                                  VerticalAlignment="Center" Margin="0,0,8,0" />
                            <!-- Status: "15 matches" or "No results for …" -->
                            <TextBlock Text="{Binding SearchStatus}"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{DynamicResource OnSurfaceVariantBrush}" />
                        </DockPanel>
                    </Border>

                    <!-- PDF viewer — WebView2 renders the document as a real PDF (native text, selectable) -->
                    <wv2:WebView2 x:Name="PdfWebView"
                                  Grid.Row="1"
                                  Visibility="{Binding IsDocumentLoaded, Converter={StaticResource BoolToVis}}" />

                    <!-- Empty state overlay -->
                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding IsDocumentEmpty, Converter={StaticResource BoolToVis}}">
                        <Path Style="{StaticResource IconPath}"
                              Data="{StaticResource IconDocument}"
                              Width="56" Height="56"
                              Stroke="{DynamicResource OutlineBrush}"
                              HorizontalAlignment="Center" />
                        <TextBlock Text="Open a PDF to get started"
                                   Style="{StaticResource TitleMedium}"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,10" />
                        <TextBlock Text="Select a file or drag &amp; drop a PDF here"
                                   Style="{StaticResource BodySmall}"
                                   Foreground="{DynamicResource OutlineBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,24" />
                        <Button Content="Open PDF"
                                Style="{StaticResource FilledButton}"
                                Command="{Binding OpenFileCommand}"
                                HorizontalAlignment="Center"
                                Padding="24,0" />
                    </StackPanel>

                </Grid>
            </Border>

            <!-- ── Merge Preview Panel (overlays PDF viewer when IsMergeMode = true) ── -->
            <Border Grid.Column="2"
                    Panel.ZIndex="20"
                    Background="{DynamicResource SurfaceBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMergeMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*"    />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="24,16">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Merge Preview"
                                           FontFamily="{DynamicResource HeadingFont}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceBrush}" />
                                <TextBlock Text="Drag · ↑ ↓ to reorder · ✕ to remove.  Satisfied? Click Execute Merge."
                                           FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="Cancel"
                                        Style="{StaticResource OutlinedButton}"
                                        Width="88" Margin="0,0,8,0"
                                        Command="{Binding CancelMergeModeCommand}" />
                                <Button Content="Execute Merge →"
                                        Style="{StaticResource FilledButton}"
                                        Padding="16,0" Height="36"
                                        Command="{Binding ExecuteMergeCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Card grid -->
                    <ScrollViewer x:Name="MergeScrollViewer"
                                  Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Background="{DynamicResource DocumentCanvasBrush}"
                                  Padding="16,16,16,8">
                        <ItemsControl ItemsSource="{Binding MergeQueueItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"
                                               Width="{Binding ViewportWidth, ElementName=MergeScrollViewer}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Card -->
                                    <Border Width="182"
                                            Margin="6,6"
                                            Background="{DynamicResource SurfaceContainerLowestBrush}"
                                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Effect="{StaticResource PageShadow}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <!-- Thumbnail area -->
                                                <RowDefinition Height="220" />
                                                <!-- File info -->
                                                <RowDefinition Height="Auto" />
                                                <!-- Action buttons -->
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- ── Thumbnail area ── -->
                                            <Border Grid.Row="0"
                                                    Background="{DynamicResource SurfaceContainerLowBrush}"
                                                    CornerRadius="6,6,0,0"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <!-- Loading spinner / message -->
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Text="Loading preview…"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource OutlineBrush}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- PDF thumbnail -->
                                                    <Image Source="{Binding ThumbnailBytes, Converter={StaticResource BytesToImage}}"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="4"
                                                           Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVis}}" />

                                                    <!-- Placeholder for Word docs / failed loads -->
                                                    <StackPanel HorizontalAlignment="Center"
                                                                VerticalAlignment="Center">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowPlaceholder}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="📄"
                                                                   FontSize="52"
                                                                   HorizontalAlignment="Center"
                                                                   TextOptions.TextFormattingMode="Ideal" />
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                                                   Margin="0,6,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="No preview" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsWordDocument}" Value="True">
                                                                            <Setter Property="Text" Value="Word Document" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- Index badge (top-left overlay) -->
                                                    <Border HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Margin="6,6,0,0"
                                                            Background="{DynamicResource PrimaryBrush}"
                                                            CornerRadius="4"
                                                            Padding="6,2">
                                                        <TextBlock Text="{Binding Index}"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="White" />
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- ── File info ── -->
                                            <StackPanel Grid.Row="1" Margin="10,8,10,4">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource OnSurfaceBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding FilePath}" />
                                                <TextBlock Text="{Binding PageCountLabel}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource OutlineBrush}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- ── Action buttons ── -->
                                            <Grid Grid.Row="2" Margin="8,0,8,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Content="↑"
                                                        Style="{StaticResource OutlinedButton}"
                                                        Height="34" FontSize="14"
                                                        Margin="0,0,2,0"
                                                        ToolTip="Move earlier"
                                                        Command="{Binding DataContext.MoveMergeItemUpCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="1"
                                                        Content="↓"
                                                        Style="{StaticResource OutlinedButton}"
                                                        Height="34" FontSize="14"
                                                        Margin="0,0,2,0"
                                                        ToolTip="Move later"
                                                        Command="{Binding DataContext.MoveMergeItemDownCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="2"
                                                        Content="✕"
                                                        Style="{StaticResource OutlinedButton}"
                                                        Height="34" FontSize="13"
                                                        ToolTip="Remove from merge"
                                                        Command="{Binding DataContext.RemoveMergeItemCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Footer status -->
                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="24,10">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} file(s) will be merged in the order shown.">
                                    <Binding Path="MergeQueueItems.Count" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>

                </Grid>
            </Border>

            <!-- ── Split Preview Panel (overlays PDF viewer when IsSplitMode = true) ── -->
            <Border Grid.Column="2"
                    Panel.ZIndex="20"
                    Background="{DynamicResource SurfaceBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSplitMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*"    />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="24,16">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Split Preview"
                                           FontFamily="{DynamicResource HeadingFont}"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource OnSurfaceBrush}" />
                                <TextBlock Text="Check pages to select · ⊕ to zoom · Extract selected to one PDF, or split every page into its own file."
                                           FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="Select All"
                                        Style="{StaticResource OutlinedButton}"
                                        Width="90" Margin="0,0,8,0"
                                        Command="{Binding SelectAllSplitPagesCommand}" />
                                <Button Content="Deselect All"
                                        Style="{StaticResource OutlinedButton}"
                                        Width="96" Margin="0,0,8,0"
                                        Command="{Binding DeselectAllSplitPagesCommand}" />
                                <Button Content="Cancel"
                                        Style="{StaticResource OutlinedButton}"
                                        Width="80"
                                        Command="{Binding CancelSplitModeCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Card grid -->
                    <ScrollViewer x:Name="SplitScrollViewer"
                                  Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  Background="{DynamicResource DocumentCanvasBrush}"
                                  Padding="16,16,16,8">
                        <ItemsControl ItemsSource="{Binding SplitPreviewItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"
                                               Width="{Binding ViewportWidth, ElementName=SplitScrollViewer}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Card with selection border -->
                                    <Border Width="155"
                                            Margin="6,6"
                                            CornerRadius="6"
                                            Effect="{StaticResource PageShadow}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowestBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource OutlineVariantBrush}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="200" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Thumbnail area -->
                                            <Border Grid.Row="0"
                                                    CornerRadius="5,5,0,0"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource SurfaceContainerLowBrush}">
                                                <Grid>
                                                    <!-- Page image -->
                                                    <Image Source="{Binding ThumbnailBytes, Converter={StaticResource BytesToImage}}"
                                                           Stretch="Uniform"
                                                           Margin="4" />

                                                    <!-- Selection tint overlay -->
                                                    <Border IsHitTestVisible="False">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#330078D4" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>

                                                    <!-- CheckBox (top-right) -->
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              HorizontalAlignment="Right"
                                                              VerticalAlignment="Top"
                                                              Margin="0,6,6,0"
                                                              ToolTip="Select this page" />

                                                    <!-- Page number badge (bottom-left) -->
                                                    <Border HorizontalAlignment="Left"
                                                            VerticalAlignment="Bottom"
                                                            Margin="6,0,0,6"
                                                            Background="#CC000000"
                                                            CornerRadius="3"
                                                            Padding="5,2">
                                                        <TextBlock Text="{Binding PageLabel}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="White" />
                                                    </Border>

                                                    <!-- Zoom button (bottom-right) -->
                                                    <Button HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Margin="0,0,6,6"
                                                            Width="28" Height="28"
                                                            Content="⊕"
                                                            FontSize="15"
                                                            Style="{StaticResource OutlinedButton}"
                                                            Padding="0"
                                                            ToolTip="View page larger"
                                                            Command="{Binding DataContext.ZoomSplitPageCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </Border>

                                            <!-- Page label below thumbnail -->
                                            <Border Grid.Row="1" Padding="8,6">
                                                <TextBlock Text="{Binding PageLabel}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource OnSurfaceBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="24,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}">
                                    <Run Text="{Binding SelectedSplitCount, Mode=OneWay}" />
                                    <Run Text=" page(s) selected" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Selected → One PDF"
                                        Style="{StaticResource OutlinedButton}"
                                        Padding="16,0" Height="36"
                                        Margin="0,0,8,0"
                                        ToolTip="Save the checked pages as a single PDF file"
                                        Command="{Binding ExecuteSplitSelectedCommand}" />
                                <Button Content="Every Page → Separate File"
                                        Style="{StaticResource FilledButton}"
                                        Padding="16,0" Height="36"
                                        ToolTip="Split all pages — each page becomes its own PDF file"
                                        Command="{Binding ExecuteSplitAllCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- Splitter right -->
            <GridSplitter Grid.Column="3" Width="4" Background="Transparent"
                          HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <!-- ── Properties Panel ── -->
            <Border Grid.Column="4"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16,16">

                        <!-- Document properties -->
                        <TextBlock Text="PROPERTIES" Style="{StaticResource SectionHeader}" />

                        <StackPanel Margin="0,4,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FILENAME" Style="{StaticResource PropertyLabel}" VerticalAlignment="Top" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DocumentInfo.FileName}"
                                           Style="{StaticResource BodySmall}"
                                           TextWrapping="Wrap"
                                           ToolTip="{Binding DocumentInfo.FilePath}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="AUTHOR" Style="{StaticResource PropertyLabel}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DocumentInfo.Author}"
                                           Style="{StaticResource BodySmall}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PAGES" Style="{StaticResource PropertyLabel}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DocumentInfo.PageCount}"
                                           Style="{StaticResource BodySmall}" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SIZE" Style="{StaticResource PropertyLabel}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DocumentInfo.FileSizeKB, StringFormat='{}{0} KB'}"
                                           Style="{StaticResource BodySmall}" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PDF VER." Style="{StaticResource PropertyLabel}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DocumentInfo.PdfVersion}"
                                           Style="{StaticResource BodySmall}" />
                            </Grid>
                        </StackPanel>

                        <Separator Style="{StaticResource PanelSeparator}" Margin="0,12,0,12" />

                        <!-- Quick actions 2×2 grid -->
                        <TextBlock Text="QUICK ACTIONS" Style="{StaticResource SectionHeader}" />
                        <UniformGrid Rows="2" Columns="2" Margin="0,4,0,0">
                            <Button Style="{StaticResource QuickActionButton}"
                                    Command="{Binding SignCommand}"
                                    Margin="0,0,3,3" ToolTip="Sign document">
                                <StackPanel HorizontalAlignment="Center">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconSign}"
                                          HorizontalAlignment="Center" Margin="0,0,0,4" />
                                    <TextBlock Text="Sign" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource QuickActionButton}"
                                    Command="{Binding RedactCommand}"
                                    Margin="3,0,0,3" ToolTip="Redact content">
                                <StackPanel HorizontalAlignment="Center">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconRedact}"
                                          HorizontalAlignment="Center" Margin="0,0,0,4" />
                                    <TextBlock Text="Redact" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource QuickActionButton}"
                                    Command="{Binding OcrCommand}"
                                    Margin="0,3,3,0" ToolTip="Run OCR">
                                <StackPanel HorizontalAlignment="Center">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconOcr}"
                                          HorizontalAlignment="Center" Margin="0,0,0,4" />
                                    <TextBlock Text="OCR" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource QuickActionButton}"
                                    Command="{Binding ExportToImageCommand}"
                                    Margin="3,3,0,0" ToolTip="Export to image">
                                <StackPanel HorizontalAlignment="Center">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconExport}"
                                          HorizontalAlignment="Center" Margin="0,0,0,4" />
                                    <TextBlock Text="Export" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <Separator Style="{StaticResource PanelSeparator}" Margin="0,12,0,12" />

                        <!-- Workflows -->
                        <TextBlock Text="WORKFLOWS" Style="{StaticResource SectionHeader}" />
                        <Button Style="{StaticResource FilledButton}"
                                Command="{Binding OpenBatchWorkflowCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource IconPathOnPrimary}"
                                      Data="{StaticResource IconBatch}"
                                      Margin="0,0,6,0" />
                                <TextBlock Text="New Batch Workflow" />
                            </StackPanel>
                        </Button>

                        <Separator Style="{StaticResource PanelSeparator}" Margin="0,12,0,12" />

                        <!-- OCR Review -->
                        <TextBlock Text="OCR REVIEW" Style="{StaticResource SectionHeader}" />
                        <Button Content="Review OCR Results"
                                Style="{StaticResource OutlinedButton}"
                                Command="{Binding OpenOcrReviewCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,4,0,0" />

                        <Separator Style="{StaticResource PanelSeparator}" Margin="0,12,0,12" />

                        <!-- More actions -->
                        <TextBlock Text="MORE" Style="{StaticResource SectionHeader}" />
                        <Button Content="Print…"
                                Style="{StaticResource FlatButton}"
                                Command="{Binding PrintCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Margin="0,0,0,4" />
                        <Button Content="Properties…"
                                Style="{StaticResource FlatButton}"
                                Command="{Binding PropertiesCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left" />

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="2"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource ToolbarBorderBrush}"
                BorderThickness="0,1,0,0">
            <StatusBar Style="{StaticResource AppStatusBar}" Padding="12,0">
                <StatusBarItem>
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="12"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}" />
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Pages: "
                                   FontSize="12"
                                   Foreground="{DynamicResource OutlineBrush}" />
                        <TextBlock Text="{Binding TotalPages}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariantBrush}" />
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>
        </Border>

    </Grid>
</Window>
