<UserControl x:Class="PDFAgent.App.Views.OcrReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PDFAgent.App.Converters"
             Background="{DynamicResource SurfaceBrush}"
             FontFamily="{DynamicResource BodyFont}">

    <UserControl.Resources>
        <converters:BytesToImageConverter x:Key="BytesToImage" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceContainerLowBrush}"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock DockPanel.Dock="Left"
                           Text="OCR Review"
                           FontFamily="{DynamicResource HeadingFont}"
                           FontSize="22"
                           Foreground="{DynamicResource PrimaryBrush}" />

                <!-- Page navigation -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="24,0,0,0">
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding PreviousPageCommand}" ToolTip="Previous page">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconPrev}" />
                    </Button>
                    <TextBlock VerticalAlignment="Center" Margin="4,0" FontSize="13">
                        <Run Text="Page " Foreground="{DynamicResource OnSurfaceVariantBrush}" />
                        <Run Text="{Binding CurrentPage}" FontWeight="SemiBold" />
                        <Run Text=" / " Foreground="{DynamicResource OutlineBrush}" />
                        <Run Text="{Binding TotalPages}" />
                    </TextBlock>
                    <Button Style="{StaticResource IconButton}"
                            Command="{Binding NextPageCommand}" ToolTip="Next page">
                        <Path Style="{StaticResource IconPath}" Data="{StaticResource IconNext}" />
                    </Button>
                </StackPanel>

                <!-- Confidence badge -->
                <Border DockPanel.Dock="Right"
                        Background="{DynamicResource SecondaryContainerBrush}"
                        CornerRadius="12" Padding="10,4" Margin="8,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource OnSecondaryContainerBrush}" FontSize="12">
                        <Run Text="Confidence: " />
                        <Run Text="{Binding Confidence, StringFormat='{}{0:P0}'}" FontWeight="SemiBold" />
                    </TextBlock>
                </Border>

                <!-- Action buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource OutlinedButton}"
                            Command="{Binding RejectPageCommand}"
                            Foreground="{DynamicResource ErrorBrush}"
                            BorderBrush="{DynamicResource ErrorBrush}"
                            Margin="0,0,8,0" ToolTip="Reject OCR for this page">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPath}"
                                  Data="{StaticResource IconReject}"
                                  Stroke="{DynamicResource ErrorBrush}"
                                  Margin="0,0,6,0" />
                            <TextBlock Text="Reject" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource FilledButton}"
                            Command="{Binding AcceptPageCommand}"
                            ToolTip="Accept OCR result for this page">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource IconPathOnPrimary}"
                                  Data="{StaticResource IconAccept}"
                                  Margin="0,0,6,0" />
                            <TextBlock Text="Accept" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Main split pane ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- Left: scanned image -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceContainerBrush}"
                    BorderBrush="{DynamicResource OutlineVariantBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceContainerLowBrush}"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="SCANNED IMAGE"
                                       Style="{StaticResource SectionHeader}" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Style="{StaticResource IconButton}"
                                        Command="{Binding ZoomInImageCommand}" ToolTip="Zoom in">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconZoomIn}" />
                                </Button>
                                <Button Style="{StaticResource IconButton}"
                                        Command="{Binding ZoomOutImageCommand}" ToolTip="Zoom out">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconZoomOut}" />
                                </Button>
                                <Button Style="{StaticResource IconButton}"
                                        Command="{Binding FitImageCommand}" ToolTip="Fit to window">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconFitWidth}" />
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="16">
                        <Border Background="{DynamicResource SurfaceContainerLowestBrush}"
                                Effect="{StaticResource PageShadow}"
                                HorizontalAlignment="Center">
                            <Image Source="{Binding PageImageData, Converter={StaticResource BytesToImage}}"
                                   Width="{Binding ImageZoomWidth}"
                                   Stretch="Uniform" />
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                          HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext"
                          Cursor="SizeWE" />

            <!-- Right: editable OCR text -->
            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Panel header + toolbar -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceContainerLowBrush}"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,8">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="RECOGNIZED TEXT"
                                       Style="{StaticResource SectionHeader}" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Style="{StaticResource IconButton}"
                                        Command="{Binding ReRunOcrCommand}" ToolTip="Re-run OCR">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconOcr}" />
                                </Button>
                                <Button Style="{StaticResource IconButton}"
                                        Command="{Binding CopyTextCommand}" ToolTip="Copy text">
                                    <Path Style="{StaticResource IconPath}" Data="{StaticResource IconExport}" />
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Editable text area -->
                    <TextBox Grid.Row="1"
                             Text="{Binding OcrText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBox}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="14"
                             Padding="16"
                             BorderThickness="0"
                             Background="{DynamicResource SurfaceBrush}" />

                    <!-- Word-count / confidence footer -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource SurfaceContainerLowBrush}"
                            BorderBrush="{DynamicResource OutlineVariantBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="16,6">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Style="{StaticResource BodySmall}"
                                       Foreground="{DynamicResource OnSurfaceVariantBrush}">
                                <Run Text="{Binding WordCount}" FontWeight="SemiBold" />
                                <Run Text=" words" />
                            </TextBlock>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <!-- Highlight low-confidence words toggle -->
                                <ToggleButton Style="{StaticResource ChipButton}"
                                              IsChecked="{Binding ShowLowConfidenceHighlights}"
                                              Content="Highlight low confidence"
                                              Margin="0,0,8,0" />
                                <TextBlock Style="{StaticResource BodySmall}"
                                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="{Binding LowConfidenceWordCount}" FontWeight="SemiBold"
                                         Foreground="{DynamicResource ErrorBrush}" />
                                    <Run Text=" low-confidence words" />
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Footer ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceContainerLowBrush}"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource BodySmall}"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource TextButton}"
                            Command="{Binding AcceptAllCommand}"
                            Content="Accept All Pages"
                            Margin="0,0,8,0" />
                    <Button Style="{StaticResource FilledButton}"
                            Command="{Binding SaveAndCloseCommand}"
                            Content="Save &amp; Close" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
