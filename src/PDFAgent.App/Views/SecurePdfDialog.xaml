<Window x:Class="PDFAgent.App.Views.SecurePdfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Secure PDF — Set Passwords"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <StackPanel Margin="24,20">

        <TextBlock Text="Password-protect PDF"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="17" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,6"/>

        <TextBlock Text="Leave a field empty to skip that password. At least one must be set."
                   FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,20"/>

        <!-- User password -->
        <TextBlock Text="USER PASSWORD  (required to open the file)"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,6"/>
        <PasswordBox x:Name="UserPwBox"
                     FontSize="13"
                     Margin="0,0,0,16"
                     Background="{DynamicResource SurfaceVariantBrush}"
                     Foreground="{DynamicResource OnSurfaceBrush}"/>

        <!-- Owner password -->
        <TextBlock Text="OWNER PASSWORD  (required to edit / print)"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,6"/>
        <PasswordBox x:Name="OwnerPwBox"
                     FontSize="13"
                     Margin="0,0,0,8"
                     Background="{DynamicResource SurfaceVariantBrush}"
                     Foreground="{DynamicResource OnSurfaceBrush}"/>

        <TextBlock x:Name="ErrorLabel"
                   Foreground="#EF5350"
                   FontSize="12"
                   Margin="0,0,0,12"
                   Visibility="Collapsed"/>

        <Separator Background="{DynamicResource OutlineVariantBrush}" Margin="0,4,0,12"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource OutlinedButton}"
                    Width="90" Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="Apply"
                    Style="{StaticResource FilledButton}"
                    Width="90"
                    IsDefault="True"
                    Click="Apply_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
