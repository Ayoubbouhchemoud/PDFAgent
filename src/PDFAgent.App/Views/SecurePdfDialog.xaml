<Window x:Class="PDFAgent.App.Views.SecurePdfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Protect PDF"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <StackPanel Margin="24,20">

        <!-- Title -->
        <TextBlock Text="Protect PDF"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,4"/>
        <TextBlock Text="The original file is never modified. A new protected copy is saved."
                   FontSize="12"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20"/>

        <!-- ── Passwords ── -->
        <TextBlock Text="PASSWORDS"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10"/>

        <!-- User password -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="User password  (to open)"
                           FontSize="11"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="UserPwBox"
                             FontSize="13"
                             Background="{DynamicResource SurfaceVariantBrush}"
                             Foreground="{DynamicResource OnSurfaceBrush}"
                             PasswordChanged="Password_Changed"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Confirm user password"
                           FontSize="11"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="UserPwConfirmBox"
                             FontSize="13"
                             Background="{DynamicResource SurfaceVariantBrush}"
                             Foreground="{DynamicResource OnSurfaceBrush}"
                             PasswordChanged="Password_Changed"/>
            </StackPanel>
        </Grid>

        <!-- Owner password -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Owner password  (to edit settings)"
                           FontSize="11"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="OwnerPwBox"
                             FontSize="13"
                             Background="{DynamicResource SurfaceVariantBrush}"
                             Foreground="{DynamicResource OnSurfaceBrush}"
                             PasswordChanged="Password_Changed"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Confirm owner password"
                           FontSize="11"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,0,0,4"/>
                <PasswordBox x:Name="OwnerPwConfirmBox"
                             FontSize="13"
                             Background="{DynamicResource SurfaceVariantBrush}"
                             Foreground="{DynamicResource OnSurfaceBrush}"
                             PasswordChanged="Password_Changed"/>
            </StackPanel>
        </Grid>

        <TextBlock FontSize="11"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   TextWrapping="Wrap"
                   Margin="0,4,0,20">
            Leave user password empty to allow the file to open without a password.
            Restrictions are still enforced. At least one password must be set.
        </TextBlock>

        <!-- ── Restrictions ── -->
        <TextBlock Text="RESTRICTIONS  (apply to users without owner password)"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <CheckBox x:Name="AllowPrintChk"
                          Content="Allow printing"
                          IsChecked="True"
                          FontSize="13"
                          Foreground="{DynamicResource OnSurfaceBrush}"
                          Margin="0,0,0,8"
                          Checked="AllowPrint_Changed" Unchecked="AllowPrint_Changed"/>
                <CheckBox x:Name="AllowHiQPrintChk"
                          Content="Allow high-quality print"
                          IsChecked="True"
                          FontSize="13"
                          Foreground="{DynamicResource OnSurfaceBrush}"
                          Margin="16,0,0,8"/>
                <CheckBox x:Name="AllowCopyChk"
                          Content="Allow copying text / images"
                          IsChecked="True"
                          FontSize="13"
                          Foreground="{DynamicResource OnSurfaceBrush}"
                          Margin="0,0,0,8"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <CheckBox x:Name="AllowModifyChk"
                          Content="Allow document modification"
                          IsChecked="False"
                          FontSize="13"
                          Foreground="{DynamicResource OnSurfaceBrush}"
                          Margin="0,0,0,8"/>
                <CheckBox x:Name="AllowFillChk"
                          Content="Allow form filling"
                          IsChecked="True"
                          FontSize="13"
                          Foreground="{DynamicResource OnSurfaceBrush}"
                          Margin="0,0,0,8"/>
                <CheckBox x:Name="AllowAnnotChk"
                          Content="Allow comments / annotations"
                          IsChecked="True"
                          FontSize="13"
                          Foreground="{DynamicResource OnSurfaceBrush}"
                          Margin="0,0,0,8"/>
            </StackPanel>
        </Grid>

        <!-- ── Encryption level ── -->
        <TextBlock Text="ENCRYPTION"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,12,0,10"/>

        <StackPanel Margin="0,0,0,4">
            <RadioButton x:Name="Aes256Radio"
                         IsChecked="True"
                         FontSize="13"
                         Foreground="{DynamicResource OnSurfaceBrush}"
                         Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="AES-256  " FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}"/>
                    <TextBlock Text="— Recommended · PDF 1.7 / Acrobat 9+"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}" FontSize="12"/>
                </StackPanel>
            </RadioButton>
            <RadioButton x:Name="Rc4Radio"
                         FontSize="13"
                         Foreground="{DynamicResource OnSurfaceBrush}"
                         Margin="0,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="RC4-128  " FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}"/>
                    <TextBlock Text="— Legacy compatibility · PDF 1.4 / Acrobat 5+"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}" FontSize="12"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <!-- Error message -->
        <TextBlock x:Name="ErrorLabel"
                   Foreground="#EF5350"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,14,0,0"
                   Visibility="Collapsed"/>

        <Separator Background="{DynamicResource OutlineVariantBrush}" Margin="0,16,0,12"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource OutlinedButton}"
                    Width="90" Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="Protect PDF"
                    Style="{StaticResource FilledButton}"
                    Width="110"
                    IsDefault="True"
                    Click="Apply_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
