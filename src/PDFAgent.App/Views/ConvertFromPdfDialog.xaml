<Window x:Class="PDFAgent.App.Views.ConvertFromPdfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export PDF"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <StackPanel Margin="24,20">

        <TextBlock Text="Export PDF"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,4"/>

        <TextBlock x:Name="InfoLabel"
                   FontSize="12"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,16"/>

        <!-- Format selector -->
        <TextBlock Text="Output format"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,8"/>

        <StackPanel Margin="0,0,0,16">
            <RadioButton x:Name="HtmlRadio"
                         Content="HTML — selectable text, tables, images"
                         IsChecked="True"
                         FontSize="13"
                         Foreground="{DynamicResource OnSurfaceBrush}"
                         Margin="0,0,0,6"/>
            <RadioButton x:Name="DocxRadio"
                         Content="Word (.docx) — headings, bullets, code boxes"
                         FontSize="13"
                         Foreground="{DynamicResource OnSurfaceBrush}"
                         Margin="0,0,0,6"/>
            <RadioButton x:Name="XlsxRadio"
                         Content="Excel (.xlsx) — spreadsheet with tables and code blocks"
                         FontSize="13"
                         Foreground="{DynamicResource OnSurfaceBrush}"/>
        </StackPanel>

        <TextBlock TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,20">
            Requires Python 3 with pdfplumber (HTML), pdfplumber + python-docx (Word), or pdfplumber + openpyxl (Excel).
        </TextBlock>

        <Separator Background="{DynamicResource OutlineVariantBrush}" Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource OutlinedButton}"
                    Width="90" Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="Export…"
                    Style="{StaticResource FilledButton}"
                    Width="100"
                    IsDefault="True"
                    Click="Export_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
