<Window x:Class="PDFAgent.App.Views.ConvertFromPdfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export as HTML"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <StackPanel Margin="24,20">

        <TextBlock Text="Export PDF as HTML"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,4"/>

        <TextBlock x:Name="InfoLabel"
                   FontSize="12"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,20"/>

        <TextBlock TextWrapping="Wrap" FontSize="13"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,8">
            The entire document will be converted to a single HTML file with:
        </TextBlock>

        <StackPanel Margin="12,0,0,16">
            <TextBlock Text="• Real selectable text — not a screenshot"  FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2"/>
            <TextBlock Text="• Headings, paragraphs, and lists preserved" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2"/>
            <TextBlock Text="• Tables as HTML table elements"              FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2"/>
            <TextBlock Text="• Images kept as image elements"              FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" Margin="0,2"/>
        </StackPanel>

        <TextBlock TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,20">
            Requires Python 3 with pdfplumber installed on PATH.
        </TextBlock>

        <Separator Background="{DynamicResource OutlineVariantBrush}" Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource OutlinedButton}"
                    Width="90" Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="Export…"
                    Style="{StaticResource FilledButton}"
                    Width="100"
                    IsDefault="True"
                    Click="Export_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
