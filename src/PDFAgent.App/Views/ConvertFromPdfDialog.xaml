<Window x:Class="PDFAgent.App.Views.ConvertFromPdfDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export PDF as…"
        Width="500" SizeToContent="Height"
        MaxHeight="740"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <StackPanel Margin="24,20">

        <!-- Header -->
        <TextBlock Text="Export PDF as…"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,4"/>
        <TextBlock x:Name="InfoLabel"
                   FontSize="12"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,20"/>

        <!-- ── Text formats ───────────────────────────────────────────── -->
        <TextBlock Text="TEXT"
                   FontSize="10" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,6"/>

        <RadioButton x:Name="RadioTxt"   GroupName="Fmt" IsChecked="True" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Text (.txt)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="Extract text layer" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioHtml"  GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="HTML (.html)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="Web page with positioned text" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioEpub"  GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="EPUB (.epub)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="E-book format" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <!-- ── Image formats ──────────────────────────────────────────── -->
        <TextBlock Text="IMAGES"
                   FontSize="10" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,6"/>

        <RadioButton x:Name="RadioPng"   GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PNG (.png)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="Lossless, one image per page" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioJpg"   GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="JPEG (.jpg)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="Compressed, one image per page" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioSvg"   GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="SVG (.svg)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="Raster-embedded vector container" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <!-- ── PDF variants ───────────────────────────────────────────── -->
        <TextBlock Text="PDF VARIANTS"
                   FontSize="10" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,6"/>

        <RadioButton x:Name="RadioPdf"    GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PDF (copy)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="Exact copy of the current file" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioPdfA1" GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PDF/A-1b" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="ISO 19005-1 archival  [best-effort]" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioPdfA2" GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PDF/A-2b" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="ISO 19005-2 archival  [best-effort]" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioPdfA3" GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PDF/A-3b" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="ISO 19005-3 archival  [best-effort]" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioSecure" GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Secure PDF" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="Password-protected copy" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <!-- ── Office formats ─────────────────────────────────────────── -->
        <TextBlock Text="OFFICE"
                   FontSize="10" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,6"/>

        <RadioButton x:Name="RadioDocx"  GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Word (.docx)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="Document — Word COM or text fallback" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioPptx"  GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PowerPoint (.pptx)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="One slide per page (image)" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <RadioButton x:Name="RadioXlsx"  GroupName="Fmt" Checked="Format_Changed" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Excel (.xlsx)" FontSize="13" Foreground="{DynamicResource OnSurfaceBrush}" Width="160"/>
                <TextBlock Text="Extracted text, one sheet per page" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
            </StackPanel>
        </RadioButton>

        <!-- ── Format-specific options ────────────────────────────────── -->
        <Border x:Name="ImageOptionsPanel"
                Background="{DynamicResource SurfaceVariantBrush}"
                CornerRadius="6"
                Padding="14,12"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <StackPanel>

                <TextBlock Text="PAGE SCOPE"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RadioAllPages"
                                 Content="All pages (save to folder)"
                                 GroupName="Scope" IsChecked="True"
                                 Foreground="{DynamicResource OnSurfaceBrush}"
                                 FontSize="13" Margin="0,0,16,0"/>
                    <RadioButton x:Name="RadioCurrentPage"
                                 Content="Current page only"
                                 GroupName="Scope"
                                 Foreground="{DynamicResource OnSurfaceBrush}"
                                 FontSize="13"/>
                </StackPanel>

                <TextBlock Text="RESOLUTION"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="64"/>
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="DpiSlider"
                            Minimum="72" Maximum="300" Value="150"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            ValueChanged="DpiSlider_ValueChanged"
                            Margin="0,0,12,0"/>
                    <TextBlock x:Name="DpiLabel"
                               Grid.Column="1"
                               Text="150 DPI"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <Separator Background="{DynamicResource OutlineVariantBrush}" Margin="0,4,0,12"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource OutlinedButton}"
                    Width="90" Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button Content="Export…"
                    Style="{StaticResource FilledButton}"
                    Width="100"
                    IsDefault="True"
                    Click="Export_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
