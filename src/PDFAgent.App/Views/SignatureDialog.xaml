<Window x:Class="PDFAgent.App.Views.SignatureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PDFAgent.App.Converters"
        Title="Create Signature"
        Width="500" Height="480"
        MinWidth="420" MinHeight="400"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="TabRadio" TargetType="RadioButton">
            <Setter Property="Foreground"   Value="{DynamicResource OnSurfaceVariantBrush}" />
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Padding"      Value="20,12" />
            <Setter Property="FontFamily"   Value="{DynamicResource BodyFont}" />
            <Setter Property="FontSize"     Value="14" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="0,0,0,3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource StateHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- header -->
            <RowDefinition Height="Auto" />   <!-- tab bar -->
            <RowDefinition Height="*" />      <!-- tab content -->
            <RowDefinition Height="Auto" />   <!-- hint -->
            <RowDefinition Height="Auto" />   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18,24,14">
            <StackPanel>
                <TextBlock Text="Create Signature"
                           FontFamily="{DynamicResource HeadingFont}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}" />
                <TextBlock Text="Draw or upload your signature. After clicking Create, drag it anywhere on the page."
                           FontSize="12"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ── Tab bar ── -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Draw Signature"
                             GroupName="SignTabs"
                             IsChecked="{Binding IsDrawTab, Mode=TwoWay}"
                             Style="{StaticResource TabRadio}" />
                <RadioButton Content="Upload Image"
                             GroupName="SignTabs"
                             IsChecked="{Binding IsUploadTab, Mode=TwoWay}"
                             Style="{StaticResource TabRadio}" />
            </StackPanel>
        </Border>

        <!-- ── Draw tab ── -->
        <Grid Grid.Row="2" Margin="24,16"
              Visibility="{Binding IsDrawTab, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="{DynamicResource OutlineVariantBrush}"
                    BorderThickness="1" CornerRadius="6">
                <Grid>
                    <TextBlock x:Name="DrawHint"
                               Text="Draw your signature here"
                               FontSize="14"
                               Foreground="{DynamicResource OutlineBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsHitTestVisible="False" />
                    <Canvas x:Name="DrawCanvas"
                            Background="Transparent"
                            Cursor="Pen"
                            MouseDown="DrawCanvas_MouseDown"
                            MouseMove="DrawCanvas_MouseMove"
                            MouseUp="DrawCanvas_MouseUp"
                            MouseLeave="DrawCanvas_MouseLeave" />
                </Grid>
            </Border>

            <DockPanel Grid.Row="1" Margin="0,10,0,0">
                <TextBlock DockPanel.Dock="Right"
                           Text="Clear"
                           Foreground="{DynamicResource PrimaryBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           Cursor="Hand"
                           VerticalAlignment="Center"
                           MouseLeftButtonDown="ClearDrawing_Click" />
                <TextBlock Text="Use mouse or stylus to sign"
                           FontSize="12"
                           Foreground="{DynamicResource OutlineBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>

            <DockPanel Grid.Row="2" Margin="0,6,0,0">
                <TextBlock DockPanel.Dock="Left" Text="Ink weight:"
                           FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Threshold, StringFormat='{}{0:0}'}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center" Width="28" TextAlignment="Right" />
                <Slider Minimum="150" Maximum="255" Value="{Binding Threshold}"
                        VerticalAlignment="Center" />
            </DockPanel>
        </Grid>

        <!-- ── Upload tab ── -->
        <Grid Grid.Row="2" Margin="24,16"
              Visibility="{Binding IsUploadTab, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <Button DockPanel.Dock="Left"
                        Content="Browse image…"
                        Style="{StaticResource OutlinedButton}"
                        Padding="14,8" FontSize="13"
                        Click="BrowseImage_Click" />
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding UploadStatus}"
                           FontSize="13"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceContainerBrush}"
                    BorderBrush="{DynamicResource OutlineVariantBrush}"
                    BorderThickness="1" CornerRadius="6">
                <Grid>
                    <TextBlock Text="No image selected" FontSize="13"
                               Foreground="{DynamicResource OutlineBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UploadedPreview}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Image Source="{Binding UploadedPreview}"
                           Stretch="Uniform" Margin="16" MaxHeight="180" />
                </Grid>
            </Border>

            <DockPanel Grid.Row="2" Margin="0,10,0,0">
                <TextBlock DockPanel.Dock="Left" Text="Background removal:"
                           FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Threshold, StringFormat='{}{0:0}'}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center" Width="28" TextAlignment="Right" />
                <Slider Minimum="150" Maximum="255" Value="{Binding Threshold}"
                        VerticalAlignment="Center"
                        ValueChanged="ThresholdSlider_ValueChanged" />
            </DockPanel>
        </Grid>

        <!-- ── Placement hint ── -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceContainerLowBrush}"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,1,0,1"
                Padding="24,10">
            <TextBlock FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       TextWrapping="Wrap">
                <Run FontWeight="SemiBold">After creating:</Run>
                <Run>the signature appears on the current page as a sticker. Drag it to the exact position you want, then click</Run>
                <Run Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold">✓</Run>
                <Run>to apply it to the PDF.</Run>
            </TextBlock>
        </Border>

        <!-- ── Footer ── -->
        <Border Grid.Row="4" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource OutlinedButton}"
                        Width="90" Margin="0,0,8,0"
                        IsCancel="True"
                        Click="Cancel_Click" />
                <Button Content="Create Signature"
                        Style="{StaticResource FilledButton}"
                        Padding="20,0" Height="36"
                        Click="Apply_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
