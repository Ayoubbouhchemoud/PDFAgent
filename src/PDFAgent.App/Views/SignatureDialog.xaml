<Window x:Class="PDFAgent.App.Views.SignatureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PDFAgent.App.Converters"
        Title="Sign Document"
        Width="540" Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- Tab radio-button: looks like an underlined tab -->
        <Style x:Key="TabRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground"   Value="{DynamicResource OnSurfaceVariantBrush}" />
            <Setter Property="Background"   Value="Transparent" />
            <Setter Property="Padding"      Value="20,12" />
            <Setter Property="FontFamily"   Value="{DynamicResource BodyFont}" />
            <Setter Property="FontSize"     Value="14" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="Foreground"  Value="{DynamicResource PrimaryBrush}" />
                                <Setter Property="FontWeight"  Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource StateHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Placement radio button -->
        <Style x:Key="PlacementRadio" TargetType="RadioButton">
            <Setter Property="Foreground"   Value="{DynamicResource OnSurfaceVariantBrush}" />
            <Setter Property="FontFamily"   Value="{DynamicResource BodyFont}" />
            <Setter Property="FontSize"     Value="13" />
            <Setter Property="Margin"       Value="0,0,16,0" />
            <Setter Property="Cursor"       Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- header -->
            <RowDefinition Height="Auto" />   <!-- tab bar -->
            <RowDefinition Height="*" />      <!-- tab content -->
            <RowDefinition Height="Auto" />   <!-- placement -->
            <RowDefinition Height="Auto" />   <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,20,24,16">
            <TextBlock Text="Sign Document"
                       FontFamily="{DynamicResource HeadingFont}"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource OnSurfaceBrush}" />
        </Border>

        <!-- ── Tab bar ── -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Draw Signature"
                             GroupName="SignTabs"
                             IsChecked="{Binding IsDrawTab, Mode=TwoWay}"
                             Style="{StaticResource TabRadioButton}" />
                <RadioButton Content="Upload Image"
                             GroupName="SignTabs"
                             IsChecked="{Binding IsUploadTab, Mode=TwoWay}"
                             Style="{StaticResource TabRadioButton}" />
            </StackPanel>
        </Border>

        <!-- ── Draw tab content ── -->
        <Grid Grid.Row="2" Margin="24,16"
              Visibility="{Binding IsDrawTab, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Canvas area -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="{DynamicResource OutlineVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <!-- Instruction text — shown until user starts drawing -->
                    <TextBlock x:Name="DrawHint"
                               Text="Draw your signature here"
                               FontSize="14"
                               Foreground="{DynamicResource OutlineBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False" />
                    <!-- Drawing surface -->
                    <Canvas x:Name="DrawCanvas"
                            Background="Transparent"
                            Cursor="Pen"
                            MouseDown="DrawCanvas_MouseDown"
                            MouseMove="DrawCanvas_MouseMove"
                            MouseUp="DrawCanvas_MouseUp"
                            MouseLeave="DrawCanvas_MouseLeave" />
                </Grid>
            </Border>

            <!-- Threshold row -->
            <DockPanel Grid.Row="1" Margin="0,10,0,0">
                <TextBlock DockPanel.Dock="Left"
                           Text="Background removal:"
                           FontSize="12"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Threshold, StringFormat='{}{0:0}'}"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center"
                           Width="28" TextAlignment="Right" />
                <Slider Minimum="150" Maximum="255"
                        Value="{Binding Threshold}"
                        TickFrequency="5"
                        VerticalAlignment="Center" />
            </DockPanel>

            <!-- Clear button row -->
            <DockPanel Grid.Row="2" Margin="0,8,0,0">
                <TextBlock DockPanel.Dock="Left"
                           Text="Use mouse or stylus to draw"
                           FontSize="12"
                           Foreground="{DynamicResource OutlineBrush}"
                           VerticalAlignment="Center" />
                <Button DockPanel.Dock="Right"
                        Content="Clear"
                        Style="{StaticResource TextButton}"
                        FontSize="13"
                        Padding="12,6"
                        Click="ClearDrawing_Click" />
            </DockPanel>
        </Grid>

        <!-- ── Upload tab content ── -->
        <Grid Grid.Row="2" Margin="24,16"
              Visibility="{Binding IsUploadTab, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Browse row -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <Button DockPanel.Dock="Left"
                        Content="Browse image…"
                        Style="{StaticResource OutlinedButton}"
                        Padding="14,8"
                        FontSize="13"
                        Click="BrowseImage_Click" />
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding UploadStatus}"
                           FontSize="13"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <!-- Preview area -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceContainerBrush}"
                    BorderBrush="{DynamicResource OutlineVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <TextBlock Text="No image selected"
                               FontSize="13"
                               Foreground="{DynamicResource OutlineBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UploadedPreview}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Image Source="{Binding UploadedPreview}"
                           Stretch="Uniform"
                           Margin="16"
                           MaxHeight="160" />
                </Grid>
            </Border>

            <!-- Threshold slider -->
            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Text="Background removal threshold:"
                               FontSize="12"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding Threshold, StringFormat='{}{0:0}'}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center"
                               Width="28" TextAlignment="Right" />
                    <Slider Minimum="150" Maximum="255"
                            Value="{Binding Threshold}"
                            VerticalAlignment="Center"
                            ValueChanged="ThresholdSlider_ValueChanged" />
                </DockPanel>
                <TextBlock Text="Higher value removes more background. Lower value keeps more detail."
                           FontSize="11"
                           Foreground="{DynamicResource OutlineBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- ── Placement ── -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceContainerLowBrush}"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,1,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Page picker -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Page:"
                               FontSize="13"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBox Text="{Binding TargetPage, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputTextBox}"
                             Width="52" Height="34"
                             FontSize="13"
                             TextAlignment="Center" />
                    <TextBlock Text="{Binding TotalPages, StringFormat='/ {0}'}"
                               FontSize="13"
                               Foreground="{DynamicResource OutlineBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <!-- Position -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Position:"
                               FontSize="13"
                               Foreground="{DynamicResource OnSurfaceVariantBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <RadioButton Content="Bottom left"
                                 IsChecked="{Binding PlaceBottomLeft, Mode=TwoWay}"
                                 Style="{StaticResource PlacementRadio}" />
                    <RadioButton Content="Bottom center"
                                 IsChecked="{Binding PlaceBottomCenter, Mode=TwoWay}"
                                 Style="{StaticResource PlacementRadio}" />
                    <RadioButton Content="Bottom right"
                                 IsChecked="{Binding PlaceBottomRight, Mode=TwoWay}"
                                 Style="{StaticResource PlacementRadio}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Footer ── -->
        <Border Grid.Row="4" Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource OutlinedButton}"
                        Width="96" Margin="0,0,8,0"
                        IsCancel="True"
                        Click="Cancel_Click" />
                <Button Content="Apply Signature"
                        Style="{StaticResource FilledButton}"
                        Padding="20,0" Height="36"
                        Click="Apply_Click" />
            </StackPanel>
        </Border>

    </Grid>
</Window>
