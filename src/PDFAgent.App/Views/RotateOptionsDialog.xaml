<Window x:Class="PDFAgent.App.Views.RotateOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rotate Pages"
        Width="360" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="20">

        <TextBlock Text="Pages to rotate"
                   FontWeight="SemiBold" Margin="0,0,0,8" />
        <RadioButton x:Name="RadioAllPages"
                     Content="All pages"
                     GroupName="PageScope"
                     IsChecked="True"
                     Margin="0,0,0,4" />
        <RadioButton x:Name="RadioCurrentPage"
                     Content="Current page only"
                     GroupName="PageScope"
                     Margin="0,0,0,4" />
        <RadioButton x:Name="RadioPageRange"
                     Content="Page range:"
                     GroupName="PageScope"
                     Margin="0,0,0,4" />
        <TextBox x:Name="PageRangeBox"
                 Text="1"
                 Margin="20,0,0,4"
                 Width="120"
                 HorizontalAlignment="Left"
                 ToolTip="E.g. 1,3-5,7" />
        <TextBlock Text="(e.g. 1, 3-5, 7)"
                   FontSize="11"
                   Foreground="Gray"
                   Margin="20,0,0,12" />

        <Separator Margin="0,4,0,12" />

        <TextBlock Text="Rotation angle"
                   FontWeight="SemiBold" Margin="0,0,0,8" />
        <RadioButton x:Name="Radio90"
                     Content="90° clockwise"
                     GroupName="Angle"
                     IsChecked="True"
                     Margin="0,0,0,4" />
        <RadioButton x:Name="Radio180"
                     Content="180°"
                     GroupName="Angle"
                     Margin="0,0,0,4" />
        <RadioButton x:Name="Radio270"
                     Content="270° clockwise (90° counter-clockwise)"
                     GroupName="Angle"
                     Margin="0,0,0,16" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Width="80"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
            <Button Content="Rotate"
                    Width="80"
                    IsDefault="True"
                    Click="Rotate_Click" />
        </StackPanel>

    </StackPanel>
</Window>
