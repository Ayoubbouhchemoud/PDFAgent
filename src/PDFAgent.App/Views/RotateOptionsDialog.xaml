<Window x:Class="PDFAgent.App.Views.RotateOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rotate Pages"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <StackPanel Margin="24,20">

        <!-- Header -->
        <TextBlock Text="Rotate Pages"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,20" />

        <!-- Page scope section -->
        <TextBlock Text="PAGES TO ROTATE"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10" />

        <RadioButton x:Name="RadioAllPages"
                     Content="All pages"
                     GroupName="PageScope"
                     IsChecked="True"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,6" />
        <RadioButton x:Name="RadioCurrentPage"
                     Content="Current page only"
                     GroupName="PageScope"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,6" />
        <RadioButton x:Name="RadioPageRange"
                     Content="Page range:"
                     GroupName="PageScope"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,8" />

        <TextBox x:Name="PageRangeBox"
                 Text="1"
                 Style="{StaticResource InputTextBox}"
                 Width="160"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,4"
                 ToolTip="E.g. 1, 3-5, 7" />
        <TextBlock Text="e.g. 1, 3-5, 7"
                   FontSize="11"
                   Foreground="{DynamicResource OutlineBrush}"
                   Margin="0,0,0,20" />

        <!-- Separator -->
        <Separator Background="{DynamicResource OutlineVariantBrush}" Margin="0,0,0,16" />

        <!-- Rotation angle section -->
        <TextBlock Text="ROTATION ANGLE"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{DynamicResource OnSurfaceVariantBrush}"
                   Margin="0,0,0,10" />

        <RadioButton x:Name="Radio90"
                     Content="90° clockwise"
                     GroupName="Angle"
                     IsChecked="True"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,6" />
        <RadioButton x:Name="Radio180"
                     Content="180°"
                     GroupName="Angle"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,6" />
        <RadioButton x:Name="Radio270"
                     Content="270° clockwise (90° counter-clockwise)"
                     GroupName="Angle"
                     Foreground="{DynamicResource OnSurfaceBrush}"
                     FontSize="14"
                     Margin="0,0,0,24" />

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource OutlinedButton}"
                    Width="96"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="Cancel_Click" />
            <Button Content="Rotate"
                    Style="{StaticResource FilledButton}"
                    Width="96"
                    IsDefault="True"
                    Click="Rotate_Click" />
        </StackPanel>

    </StackPanel>
</Window>
