<Window x:Class="PDFAgent.App.Views.AddPageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Page"
        Width="400" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Add Blank Page"
                   FontFamily="{DynamicResource HeadingFont}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource OnSurfaceBrush}"
                   Margin="0,0,0,20" />

        <!-- Position group -->
        <StackPanel Grid.Row="1" Margin="0,0,0,18">
            <TextBlock Text="POSITION"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       Margin="0,0,0,8" />
            <RadioButton x:Name="AfterCurrentRb"
                         Content="{Binding AfterCurrentLabel}"
                         IsChecked="True"
                         Margin="0,0,0,5"
                         Foreground="{DynamicResource OnSurfaceBrush}" />
            <RadioButton x:Name="BeforeCurrentRb"
                         Content="{Binding BeforeCurrentLabel}"
                         Margin="0,0,0,5"
                         Foreground="{DynamicResource OnSurfaceBrush}" />
            <RadioButton x:Name="AtEndRb"
                         Content="At the end of the document"
                         Margin="0,0,0,5"
                         Foreground="{DynamicResource OnSurfaceBrush}" />
            <RadioButton x:Name="AtBeginningRb"
                         Content="At the beginning of the document"
                         Foreground="{DynamicResource OnSurfaceBrush}" />
        </StackPanel>

        <!-- Page size group -->
        <StackPanel Grid.Row="2" Margin="0,0,0,18">
            <TextBlock Text="PAGE SIZE"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"
                       Margin="0,0,0,8" />
            <RadioButton x:Name="SameAsCurrentRb"
                         Content="{Binding SameAsCurrentLabel}"
                         IsChecked="True"
                         Margin="0,0,0,5"
                         Foreground="{DynamicResource OnSurfaceBrush}" />
            <RadioButton x:Name="A4Rb"
                         Content="A4  (210 × 297 mm)"
                         Margin="0,0,0,5"
                         Foreground="{DynamicResource OnSurfaceBrush}" />
            <RadioButton x:Name="LetterRb"
                         Content="Letter  (8.5 × 11 in)"
                         Foreground="{DynamicResource OnSurfaceBrush}" />
        </StackPanel>

        <!-- Separator + buttons -->
        <Grid Grid.Row="4" Margin="0,4,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Separator Grid.Row="0"
                       Background="{DynamicResource OutlineVariantBrush}"
                       Margin="0,0,0,14" />
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource OutlinedButton}"
                        Width="90" Margin="0,0,8,0"
                        IsCancel="True"
                        Click="Cancel_Click" />
                <Button Content="Add Page →"
                        Style="{StaticResource FilledButton}"
                        Width="100"
                        IsDefault="True"
                        Click="Add_Click" />
            </StackPanel>
        </Grid>

    </Grid>
</Window>
