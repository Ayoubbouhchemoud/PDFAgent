<UserControl x:Class="PDFAgent.App.Views.PdfPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PDFAgent.App.Converters">

    <UserControl.Resources>
        <converters:BytesToImageConverter x:Key="BytesToImage" />
    </UserControl.Resources>

    <!--
        DataContext = RenderedPageItem.
        The outer Border (in the parent DataTemplate) applies the zoom ScaleTransform,
        so this control works at its natural 150-DPI pixel size.
        All canvas coordinates are in image pixels.
    -->
    <Grid x:Name="PageGrid" Background="Transparent"
          MouseLeftButtonDown="PageGrid_MouseDown">

        <!-- Loading placeholder — visible only while ImageData is null -->
        <Border Width="595" Height="842"
                Background="{DynamicResource SurfaceContainerBrush}"
                CornerRadius="3"
                HorizontalAlignment="Left" VerticalAlignment="Top">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ImageData}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding PageNumber, StringFormat='Page {0}'}"
                           FontSize="14" Foreground="{DynamicResource OutlineBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Loading…" FontSize="11"
                           Foreground="{DynamicResource OutlineBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Rendered page image at natural 150-DPI pixel size -->
        <Image x:Name="PageImage"
               Source="{Binding ImageData, Converter={StaticResource BytesToImage}}"
               Stretch="None"
               HorizontalAlignment="Left" VerticalAlignment="Top" />

        <!-- Sticker canvas — children are positioned absolutely, no self hit-test background -->
        <Canvas x:Name="StickerCanvas" />

        <!-- Text-annotation canvas — children positioned absolutely -->
        <Canvas x:Name="TextCanvas" />

    </Grid>
</UserControl>
