<Window x:Class="PDFAgent.App.Views.TextEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit PDF Text"
        Width="940" Height="760"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceBrush}"
        FontFamily="{DynamicResource BodyFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Grid Grid.Row="0" Margin="20,14,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock Text="Edit PDF Text"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource OnSurfaceBrush}"/>
                <TextBlock Text="Click any word to edit it. Press Enter or click elsewhere to confirm."
                           FontSize="12"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Page navigation -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="PrevBtn"
                        Content="◀"
                        Width="32" Height="32"
                        Style="{StaticResource OutlinedButton}"
                        Click="Prev_Click"
                        IsEnabled="False"
                        Margin="0,0,4,0"/>
                <TextBlock x:Name="PageLabel"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{DynamicResource OnSurfaceBrush}"
                           MinWidth="80" TextAlignment="Center"/>
                <Button x:Name="NextBtn"
                        Content="▶"
                        Width="32" Height="32"
                        Style="{StaticResource OutlinedButton}"
                        Click="Next_Click"
                        IsEnabled="False"
                        Margin="4,0,0,0"/>
            </StackPanel>
        </Grid>

        <Separator Grid.Row="0" VerticalAlignment="Bottom"
                   Background="{DynamicResource OutlineVariantBrush}"
                   Margin="0,0,0,0" Height="1"/>

        <!-- ── Page view ── -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource SurfaceVariantBrush}"
                      Padding="24">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Top">
                <!-- Loading indicator -->
                <TextBlock x:Name="LoadingLabel"
                           Text="Loading page…"
                           FontSize="14"
                           Foreground="{DynamicResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="40"/>

                <!-- Page image + word overlay canvas, same size, stacked -->
                <Grid x:Name="PageContainer" Visibility="Hidden">
                    <Image x:Name="PageImage"
                           Stretch="None"
                           HorizontalAlignment="Left" VerticalAlignment="Top"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Canvas x:Name="OverlayCanvas"
                            HorizontalAlignment="Left" VerticalAlignment="Top"
                            Background="Transparent"/>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- ── Status bar ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource OutlineVariantBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,6">
            <TextBlock x:Name="StatusLabel"
                       FontSize="12"
                       Foreground="{DynamicResource OnSurfaceVariantBrush}"/>
        </Border>

        <!-- ── Footer buttons ── -->
        <Grid Grid.Row="3" Margin="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource OutlinedButton}"
                        Width="90" Margin="0,0,8,0"
                        IsCancel="True"
                        Click="Cancel_Click"/>
                <Button x:Name="ApplyBtn"
                        Content="Apply Edits"
                        Style="{StaticResource FilledButton}"
                        Width="110"
                        IsDefault="True"
                        Click="Apply_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
